/* v39 replace tiny line charts with large bar trend cards */
.ai-chart-grid{
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr));
  gap:18px;
}
.ai-chart-card{
  border:1px solid rgba(255,255,255,.10);
  border-radius:24px;
  background:linear-gradient(180deg,rgba(20,27,48,.98),rgba(12,18,33,.98));
  padding:18px 18px 16px;
  min-width:0;
}
.ai-chart-card h4{
  margin:0 0 8px;
  font-size:24px;
  color:#fff;
}
.ai-chart-card p{
  margin:0 0 16px;
  color:#c2cee3;
  font-size:14px;
  line-height:1.45;
}
.ai-region-stack{
  display:flex;
  flex-direction:column;
  gap:14px;
}
.ai-region-row{
  display:grid;
  grid-template-columns:145px minmax(120px,1fr) auto;
  align-items:center;
  gap:10px;
}
.ai-region-row .label{
  color:#f0f4ff;
  font-size:14px;
  font-weight:700;
  line-height:1.2;
}
.ai-region-row .value{
  color:#f0f4ff;
  font-size:14px;
  font-weight:800;
  white-space:nowrap;
}
.ai-bar{
  position:relative;
  height:14px;
  border-radius:999px;
  background:rgba(255,255,255,.10);
  overflow:hidden;
}
.ai-bar > span{
  position:absolute;
  inset:0 auto 0 0;
  border-radius:999px;
}
.ai-bar > span.nnj{background:linear-gradient(90deg,#FFDF00,#E8C900)}
.ai-bar > span.pac{background:linear-gradient(90deg,#52C3D6,#70d3e2)}
.ai-bar > span.phl{background:linear-gradient(90deg,#A6E05F,#72c973)}
.ai-delta{
  margin-top:4px;
  color:#8f9db7;
  font-size:12px;
  line-height:1.2;
}
.ai-delta strong{
  font-weight:800;
  color:#dce5f7;
}
.ai-delta.up strong{color:#91e28e}
.ai-delta.down strong{color:#f2b45e}
.ai-delta.flat strong{color:#dce5f7}
.ai-chart-foot{
  display:flex;
  justify-content:space-between;
  gap:10px;
  color:#8f9db7;
  font-size:11px;
  margin-top:14px;
}
.ai-period-badge{
  display:inline-flex;
  align-items:center;
  gap:6px;
  padding:4px 8px;
  border:1px solid rgba(255,255,255,.12);
  border-radius:999px;
  color:#c9d2e4;
  font-size:11px;
  margin-bottom:10px;
}
@media(max-width:1200px){
  .ai-chart-grid{grid-template-columns:1fr}
}
@media(max-width:760px){
  .ai-region-row{
    grid-template-columns:1fr;
    gap:6px;
  }
  .ai-region-row .value{justify-self:flex-start}
}


/* v40 sortable table headers */
.table th.sortable{
  cursor:pointer;
  user-select:none;
  position:sticky;
}
.table th.sortable:hover{
  color:#FFDF00;
  background:#141d34;
}
.table th.sortable::after{
  content:' ↕';
  color:#65728d;
  font-size:10px;
}
.table th.sorted-asc::after{
  content:' ↑';
  color:#FFDF00;
}
.table th.sorted-desc::after{
  content:' ↓';
  color:#FFDF00;
}


/* v41 comp evidence table cleanup */
.table td{
  max-width:260px;
  overflow:hidden;
  text-overflow:ellipsis;
}
.table td.tight{
  max-width:280px!important;
}


/* v42 mobile Market AI fix */
@media(max-width:760px){
  .cards .ai-insights{
    display:grid!important;
    padding:14px!important;
    gap:16px!important;
  }
  .cards .ai-panel,
  .cards .ai-report-card,
  .cards .ai-chart-card{
    border-radius:18px!important;
    padding:16px!important;
  }
  .cards .ai-hero,
  .cards .ai-report-grid,
  .cards .ai-chart-grid{
    display:grid!important;
    grid-template-columns:1fr!important;
    gap:14px!important;
  }
  .cards .ai-metrics{
    grid-template-columns:repeat(2,minmax(0,1fr))!important;
    gap:10px!important;
  }
  .cards .ai-report-thumb{
    max-height:260px!important;
  }
  .cards .ai-report-card{
    display:flex!important;
    flex-direction:column!important;
  }
  .cards .ai-region-row{
    grid-template-columns:1fr!important;
    gap:6px!important;
  }
  .cards .ai-bar{
    width:100%!important;
  }
  .cards .ai-button{
    width:100%!important;
    min-height:44px!important;
  }
}


/* v43 submarket economics market AI section */
.ai-econ-section{margin-top:18px}
.ai-econ-market-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:16px}
.ai-econ-market{background:rgba(10,18,50,.55);border:1px solid rgba(255,255,255,.08);border-radius:20px;padding:18px}
.ai-econ-market h4{margin:0 0 8px;font-size:1.45rem;line-height:1.1}
.ai-econ-market p{margin:0 0 12px;color:#aeb7d1}
.ai-econ-meta{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:12px}
.ai-econ-chip{border:1px solid rgba(255,255,255,.10);background:rgba(255,255,255,.03);padding:6px 10px;border-radius:999px;color:#d8def0;font-size:.78rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase}
.ai-econ-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px}
.ai-econ-card{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:14px}
.ai-econ-card h5{margin:0 0 4px;font-size:1.2rem}
.ai-econ-card p{margin:0 0 12px;color:#aeb7d1;font-size:.92rem;line-height:1.35}
.ai-econ-row{display:grid;grid-template-columns:minmax(0,110px) 1fr auto;gap:10px;align-items:center;margin-bottom:10px}
.ai-econ-row:last-child{margin-bottom:0}
.ai-econ-name{font-size:.92rem;color:#f1f4ff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ai-econ-bar{height:12px;border-radius:999px;background:rgba(255,255,255,.08);overflow:hidden;position:relative}
.ai-econ-bar > span{display:block;height:100%;border-radius:999px;background:linear-gradient(90deg,#ffdf00 0%, #8ad06c 55%, #4aa7b8 100%)}
.ai-econ-value{font-size:.92rem;font-weight:800;white-space:nowrap;color:#f8fbff}
.ai-econ-empty{padding:8px 0;color:#aeb7d1;font-size:.95rem}
@media (max-width: 1200px){
  .ai-econ-market-grid{grid-template-columns:1fr}
}
@media (max-width: 980px){
  .ai-econ-grid{grid-template-columns:1fr}
}
@media (max-width: 760px){
  .cards .ai-econ-market-grid{grid-template-columns:1fr!important}
  .cards .ai-econ-grid{grid-template-columns:1fr!important}
  .cards .ai-econ-market{padding:16px!important}
  .cards .ai-econ-card{padding:14px!important}
}


/* v44 annualized concession intensity analysis */
.ai-concession-method{
  margin-top:12px;
  padding:14px 16px;
  border:1px solid rgba(255,223,0,.28);
  background:rgba(255,223,0,.08);
  border-radius:16px;
  color:#dfe7f6;
  font-size:.92rem;
  line-height:1.45;
}
.ai-concession-method strong{color:#ffdf00}
.ai-econ-market-grid{display:grid;grid-template-columns:1fr;gap:18px}
.ai-econ-market{background:rgba(10,18,50,.55);border:1px solid rgba(255,255,255,.08);border-radius:20px;padding:18px}
.ai-econ-market h4{margin:0 0 8px;font-size:1.45rem;line-height:1.1}
.ai-econ-market p{margin:0 0 12px;color:#aeb7d1}
.ai-econ-meta{display:flex;gap:10px;flex-wrap:wrap;margin-bottom:14px}
.ai-econ-chip{border:1px solid rgba(255,255,255,.10);background:rgba(255,255,255,.03);padding:6px 10px;border-radius:999px;color:#d8def0;font-size:.78rem;font-weight:700;letter-spacing:.04em;text-transform:uppercase}
.ai-econ-grid{display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:12px}
.ai-econ-card{background:rgba(255,255,255,.03);border:1px solid rgba(255,255,255,.07);border-radius:16px;padding:14px;min-width:0}
.ai-econ-card h5{margin:0 0 4px;font-size:1.08rem;line-height:1.15}
.ai-econ-card p{margin:0 0 12px;color:#aeb7d1;font-size:.86rem;line-height:1.35}
.ai-econ-row{display:grid;grid-template-columns:minmax(0,110px) 1fr auto;gap:10px;align-items:center;margin-bottom:10px}
.ai-econ-row:last-child{margin-bottom:0}
.ai-econ-name{font-size:.86rem;color:#f1f4ff;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
.ai-econ-bar{height:12px;border-radius:999px;background:rgba(255,255,255,.08);overflow:hidden;position:relative}
.ai-econ-bar > span{display:block;height:100%;border-radius:999px;background:linear-gradient(90deg,#ffdf00 0%, #8ad06c 55%, #4aa7b8 100%)}
.ai-econ-value{font-size:.86rem;font-weight:800;white-space:nowrap;color:#f8fbff}
.ai-econ-empty{padding:8px 0;color:#aeb7d1;font-size:.95rem}
.ai-econ-note{margin-top:10px;color:#8d99b5;font-size:.78rem;line-height:1.35}
@media (max-width: 1400px){.ai-econ-grid{grid-template-columns:repeat(2,minmax(0,1fr))}}
@media (max-width: 900px){.ai-econ-grid{grid-template-columns:1fr}.ai-econ-row{grid-template-columns:minmax(0,105px) 1fr auto}}
@media (max-width: 760px){
  .cards .ai-econ-market-grid{grid-template-columns:1fr!important}
  .cards .ai-econ-grid{grid-template-columns:1fr!important}
  .cards .ai-econ-market{padding:16px!important}
  .cards .ai-econ-card{padding:14px!important}
  .cards .ai-econ-row{grid-template-columns:1fr!important;gap:6px!important}
}


/* v45 client-ready mobile filters and sort */
.mobile-controls{display:none}
.mobile-sort{display:flex;align-items:center;gap:8px;min-width:0;flex:1}
.mobile-sort label{font-size:10px;text-transform:uppercase;letter-spacing:1.3px;color:#8f9db5;font-weight:900}
.mobile-sort select{flex:1;min-width:0;height:42px;border:1px solid rgba(255,255,255,.12);border-radius:12px;background:rgba(255,255,255,.04);color:#fff;padding:0 10px;font-weight:800}
.mobile-control-btn{height:42px;border:0;border-radius:999px;background:#FFDF00;color:#111;font-weight:950;padding:0 15px}
.mobile-control-btn.secondary{background:rgba(255,255,255,.08);color:#fff;border:1px solid rgba(255,255,255,.12)}
.filter-close{display:none}
@media(max-width:760px){
  .mobile-controls{display:flex;gap:10px;align-items:center;margin:0 0 12px;padding:0 2px}
  .mobile-intro{margin-bottom:8px!important}
  .filters{padding:18px 16px 24px!important}
  .filter-close{display:block;width:100%;height:44px;margin:0 0 14px;border:0;border-radius:999px;background:#FFDF00;color:#111;font-weight:950}
  .sidebar-header{margin-bottom:12px!important;padding-bottom:12px!important}
  .nav-stack{grid-template-columns:1fr 1fr;gap:8px}
  .sidebar-link{justify-content:center;text-align:center;padding:11px 10px;font-size:13px}
}
@media(min-width:761px){.mobile-controls{display:none!important}}


/* v47 final responsive polish */
@media(min-width:1181px){
  .topbar{min-height:88px!important}
  .brand-cluster{min-width:0!important}
  .title{max-width:min(760px,48vw)!important}
  .toolbar-search{max-width:420px!important}
}
@media(max-width:1180px) and (min-width:761px){
  .wrap{grid-template-columns:1fr!important}
  .filters{position:static!important;display:none}
  .filters.open{display:block!important}
  .kpis{grid-template-columns:repeat(2,minmax(0,1fr))!important}
  .map-card{height:460px!important}
}
@media(max-width:760px){
  .map-card{height:390px!important}
  .tabs{grid-template-columns:repeat(2,minmax(0,1fr))!important}
  .tab{font-size:14px!important;line-height:1.1!important}
  .section-head h2{font-size:24px!important}
  .record-title{font-size:18px!important}
  .ai-modal-card{width:96vw!important}
  .report-page-img{padding:6px!important}
}


/* v48 mobile tab/content and comp economics label fixes */
@media(max-width:760px){
  .cards{display:grid!important}
  .table-wrap{display:none!important}
  .cards .ai-insights{display:grid!important}
  .tabs .tab[data-tab="comps"]{font-size:15px!important}
}
@media(min-width:761px){
  .cards{display:none!important}
  .table-wrap{display:block!important}
}


/* v49 two-hour password gate */
.auth-gate{position:fixed;inset:0;z-index:99999;background:radial-gradient(circle at 20% 0%,rgba(255,223,0,.12),transparent 30%),linear-gradient(180deg,#080d18,#0b1224);display:flex;align-items:center;justify-content:center;padding:24px;color:#fff}
.auth-gate.hidden{display:none}
.auth-card{width:min(460px,92vw);border:1px solid rgba(255,255,255,.12);border-radius:24px;background:rgba(16,24,43,.94);box-shadow:0 28px 90px rgba(0,0,0,.45);padding:28px}
.auth-logo{width:70px;height:70px;border-radius:12px;background:#FFDF00;color:#c90c0f;display:flex;align-items:center;justify-content:center;font-weight:900;font-size:20px;text-transform:lowercase;margin-bottom:18px;box-shadow:0 12px 32px rgba(255,223,0,.18)}
.auth-card h1{font-size:26px;line-height:1.1;margin:0 0 8px}
.auth-card p{color:#aeb9d0;line-height:1.45;margin:0 0 18px}
.auth-field{display:grid;gap:8px;margin-bottom:14px}
.auth-field label{font-size:11px;text-transform:uppercase;letter-spacing:1.4px;color:#98a6be;font-weight:900}
.auth-field input{height:50px;border-radius:14px;border:1px solid rgba(255,255,255,.14);background:rgba(255,255,255,.05);color:#fff;padding:0 14px;outline:none;font-size:16px}
.auth-field input:focus{box-shadow:0 0 0 3px rgba(255,223,0,.12)}
.auth-btn{height:50px;width:100%;border:0;border-radius:999px;background:#FFDF00;color:#111;font-weight:950;font-size:16px;cursor:pointer}
.auth-error{display:none;margin-top:12px;color:#ffb7b7;font-size:13px}
.auth-error.show{display:block}
.auth-note{margin-top:14px;font-size:12px;color:#7f8da8}
body.auth-locked{overflow:hidden}
body.auth-locked .app{filter:blur(6px);pointer-events:none;user-select:none}


/* v50 definitive mobile Market AI render fix */
.ai-region-stack{display:flex;flex-direction:column;gap:14px}
.ai-region-row{display:grid;grid-template-columns:145px minmax(120px,1fr) auto;align-items:center;gap:10px}
.ai-region-row .label{color:#f0f4ff;font-size:14px;font-weight:700;line-height:1.2}
.ai-region-row .value{color:#f0f4ff;font-size:14px;font-weight:800;white-space:nowrap}
.ai-bar{position:relative;height:14px;border-radius:999px;background:rgba(255,255,255,.10);overflow:hidden}
.ai-bar > span{position:absolute;inset:0 auto 0 0;border-radius:999px;display:block;height:100%}
.ai-bar > span.nnj{background:linear-gradient(90deg,#FFDF00,#E8C900)}
.ai-bar > span.pac{background:linear-gradient(90deg,#52C3D6,#70d3e2)}
.ai-bar > span.phl{background:linear-gradient(90deg,#A6E05F,#72c973)}
.ai-delta{margin-top:4px;color:#8f9db7;font-size:12px;line-height:1.2}
.ai-delta strong{font-weight:800;color:#dce5f7}
.ai-delta.up strong{color:#91e28e}
.ai-delta.down strong{color:#f2b45e}
.ai-delta.flat strong{color:#dce5f7}
.ai-period-badge{display:inline-flex;align-items:center;gap:6px;padding:4px 8px;border:1px solid rgba(255,255,255,.12);border-radius:999px;color:#c9d2e4;font-size:11px;margin-bottom:10px}
@media(max-width:760px){
  .cards{display:grid!important}
  .cards .ai-insights{display:grid!important;padding:14px!important;gap:16px!important}
  .cards .ai-panel,.cards .ai-report-card,.cards .ai-chart-card{border-radius:18px!important;padding:16px!important}
  .cards .ai-hero,.cards .ai-report-grid,.cards .ai-chart-grid,.cards .ai-econ-market-grid{display:grid!important;grid-template-columns:1fr!important;gap:14px!important}
  .cards .ai-metrics,.cards .ai-econ-grid{grid-template-columns:1fr!important}
  .cards .ai-region-row{grid-template-columns:1fr!important;gap:6px!important}
  .cards .ai-bar{width:100%!important}
}


/* v51 market AI submarket bar color refinement */
.ai-bars .ai-bar i.subbar-0{background:linear-gradient(90deg,#FFDF00,#F2C300)!important}
.ai-bars .ai-bar i.subbar-1{background:linear-gradient(90deg,#238291,#52C3D6)!important}
.ai-bars .ai-bar i.subbar-2{background:linear-gradient(90deg,#A6E05F,#6BBF59)!important}
.ai-bars .ai-bar i.subbar-3{background:linear-gradient(90deg,#F2B45E,#D88735)!important}
.ai-bars .ai-bar i.subbar-4{background:linear-gradient(90deg,#8D9FD6,#6477B7)!important}
.ai-bars .ai-bar i.subbar-5{background:linear-gradient(90deg,#D7DCE5,#9AA4B8)!important}
.ai-bars .ai-bar-row.overall{
  border:1px solid rgba(255,223,0,.20);
  background:rgba(255,223,0,.06);
  border-radius:12px;
  padding:7px 8px;
  margin-bottom:2px;
}
.ai-bars .ai-bar-row.overall span,
.ai-bars .ai-bar-row.overall strong{
  color:#fff!important;
  font-weight:900!important;
}


/* v52 mobile Market AI width / nested gutter fix */
@media(max-width:760px){
  html,body{
    max-width:100vw!important;
    overflow-x:hidden!important;
  }
  .wrap{
    padding-left:0!important;
    padding-right:0!important;
    max-width:100vw!important;
    overflow-x:hidden!important;
  }
  .main{
    width:100%!important;
    max-width:100vw!important;
    overflow-x:hidden!important;
  }
  .data-card{
    width:100%!important;
    max-width:100vw!important;
    border-left:0!important;
    border-right:0!important;
    border-radius:0!important;
    overflow:hidden!important;
  }
  .cards{
    width:100%!important;
    max-width:100vw!important;
    padding:10px 8px 18px!important;
    overflow:visible!important;
  }
  .cards .ai-insights{
    width:100%!important;
    max-width:100%!important;
    padding:0!important;
    gap:14px!important;
  }
  .cards .ai-panel{
    width:100%!important;
    max-width:100%!important;
    padding:14px!important;
    border-radius:16px!important;
    overflow:hidden!important;
  }
  .cards .ai-report-card,
  .cards .ai-chart-card,
  .cards .ai-econ-market,
  .cards .ai-econ-card{
    width:100%!important;
    max-width:100%!important;
    padding:12px!important;
    border-radius:16px!important;
    overflow:hidden!important;
  }
  .cards .ai-econ-market-grid,
  .cards .ai-econ-grid,
  .cards .ai-chart-grid,
  .cards .ai-report-grid,
  .cards .ai-metrics{
    width:100%!important;
    max-width:100%!important;
    grid-template-columns:1fr!important;
    gap:12px!important;
  }
  .cards .ai-econ-row{
    display:grid!important;
    grid-template-columns:1fr!important;
    gap:6px!important;
    margin-bottom:14px!important;
  }
  .cards .ai-econ-name{
    white-space:normal!important;
    overflow:visible!important;
    text-overflow:clip!important;
    line-height:1.25!important;
  }
  .cards .ai-econ-bar,
  .cards .ai-bar{
    width:100%!important;
    min-width:0!important;
  }
  .cards .ai-econ-value{
    justify-self:start!important;
    font-size:15px!important;
  }
  .cards .ai-concession-method{
    padding:12px!important;
    font-size:13px!important;
  }
  .cards .ai-report-thumb{
    max-height:240px!important;
  }
}


/* v54 readable dropdown option fix */
.field select,
.mobile-sort select{
  color:#f4f7ff!important;
  background-color:#151c31!important;
  color-scheme:dark;
}
.field select option,
.mobile-sort select option{
  color:#f4f7ff!important;
  background:#151c31!important;
}
.field select option:checked,
.field select option:hover,
.mobile-sort select option:checked,
.mobile-sort select option:hover{
  color:#111!important;
  background:#FFDF00!important;
}
.field select:focus,
.mobile-sort select:focus{
  border-color:rgba(255,223,0,.45)!important;
  box-shadow:0 0 0 3px rgba(255,223,0,.13)!important;
}



/* v55 3-second landing splash */
.intro-splash{
  position:fixed;
  inset:0;
  z-index:99998;
  display:flex;
  align-items:center;
  justify-content:center;
  overflow:hidden;
  background:
    radial-gradient(circle at 62% 28%, rgba(255,223,0,.18), transparent 14%),
    radial-gradient(circle at 25% 55%, rgba(255,223,0,.10), transparent 22%),
    linear-gradient(120deg,#050911 0%,#07111f 40%,#061626 100%);
  color:#fff;
  opacity:1;
  transition:opacity .7s ease, visibility .7s ease;
}
.intro-splash.hide{
  opacity:0;
  visibility:hidden;
  pointer-events:none;
}
.intro-map{
  position:absolute;
  inset:-8%;
  background:
    radial-gradient(circle at 45% 40%, rgba(255,223,0,.34) 0 3px, transparent 4px),
    radial-gradient(circle at 62% 28%, rgba(255,223,0,.38) 0 4px, transparent 5px),
    radial-gradient(circle at 38% 67%, rgba(255,223,0,.30) 0 3px, transparent 4px),
    radial-gradient(circle at 72% 62%, rgba(255,223,0,.28) 0 3px, transparent 4px),
    linear-gradient(90deg, transparent 0 48%, rgba(255,223,0,.16) 49%, transparent 51%),
    linear-gradient(25deg, transparent 0 51%, rgba(255,223,0,.12) 52%, transparent 54%),
    linear-gradient(155deg, transparent 0 44%, rgba(35,130,145,.14) 45%, transparent 48%);
  opacity:.8;
  filter:blur(.1px);
  transform:scale(1.04);
}
.intro-map:after{
  content:"";
  position:absolute;
  inset:0;
  background-image:
    linear-gradient(rgba(255,255,255,.035) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,.035) 1px, transparent 1px);
  background-size:48px 48px;
  mask-image:radial-gradient(circle at center, #000 0%, transparent 72%);
}
.intro-lines{
  position:absolute;
  inset:0;
  background:
    conic-gradient(from 18deg at 62% 30%, transparent 0 22%, rgba(255,223,0,.32) 23%, transparent 26% 100%),
    conic-gradient(from 140deg at 45% 42%, transparent 0 19%, rgba(255,223,0,.22) 21%, transparent 25% 100%),
    conic-gradient(from 260deg at 38% 67%, transparent 0 20%, rgba(255,223,0,.25) 22%, transparent 26% 100%);
  opacity:.4;
  animation:introPulse 2.8s ease-in-out infinite;
}
.intro-content{
  width:min(1180px,94vw);
  position:relative;
  z-index:2;
  display:grid;
  grid-template-columns:1.1fr .9fr;
  gap:44px;
  align-items:center;
}
.intro-brand{
  display:flex;
  align-items:center;
  gap:22px;
  margin-bottom:34px;
}
.intro-logo{
  width:92px;
  height:92px;
  border-radius:6px;
  background:#FFDF00;
  color:#c90c0f;
  display:flex;
  align-items:center;
  justify-content:center;
  font-size:28px;
  font-weight:900;
  text-transform:lowercase;
  box-shadow:0 0 38px rgba(255,223,0,.25);
}
.intro-brand-text{
  padding-left:18px;
  border-left:1px solid rgba(255,255,255,.35);
  font-size:24px;
  line-height:1.16;
}
.intro-brand-text strong{
  display:block;
  color:#FFDF00;
  font-weight:500;
}
.intro-kicker{
  color:#FFDF00;
  font-weight:900;
  letter-spacing:5px;
  text-transform:uppercase;
  margin-bottom:18px;
}
.intro-title{
  font-size:clamp(46px,6.4vw,86px);
  line-height:.94;
  font-weight:950;
  letter-spacing:-3px;
  max-width:760px;
}
.intro-sub{
  margin-top:22px;
  font-size:20px;
  color:#d8dfef;
  max-width:660px;
  line-height:1.4;
}
.intro-pills{
  display:flex;
  gap:10px;
  flex-wrap:wrap;
  margin-top:28px;
}
.intro-pill{
  border:1px solid rgba(255,223,0,.28);
  background:rgba(9,16,31,.72);
  border-radius:999px;
  padding:10px 14px;
  font-size:12px;
  letter-spacing:1.1px;
  font-weight:900;
  text-transform:uppercase;
}
.intro-card{
  border:1px solid rgba(255,223,0,.35);
  border-radius:24px;
  background:linear-gradient(180deg,rgba(16,25,43,.84),rgba(6,12,24,.88));
  box-shadow:0 24px 72px rgba(0,0,0,.42), inset 0 0 60px rgba(255,223,0,.05);
  padding:28px;
  justify-self:end;
  width:min(420px,100%);
}
.intro-card-icon{
  width:58px;height:58px;border:1px solid rgba(255,223,0,.42);border-radius:18px;color:#FFDF00;display:flex;align-items:center;justify-content:center;font-size:28px;margin-bottom:18px;
}
.intro-card h2{
  color:#FFDF00;
  letter-spacing:5px;
  font-size:13px;
  text-align:left;
  margin:0 0 10px;
}
.intro-card p{
  color:#cfd8ea;
  margin:0 0 18px;
  line-height:1.45;
}
.intro-progress{
  height:6px;
  background:rgba(255,255,255,.10);
  border-radius:999px;
  overflow:hidden;
}
.intro-progress span{
  display:block;
  height:100%;
  width:0%;
  border-radius:999px;
  background:linear-gradient(90deg,#FFDF00,#238291);
  animation:introLoad 2.7s ease forwards;
}
@keyframes introLoad{to{width:100%}}
@keyframes introPulse{0%,100%{opacity:.35;transform:scale(1)}50%{opacity:.65;transform:scale(1.02)}}
@media(max-width:900px){
  .intro-content{grid-template-columns:1fr;gap:24px}
  .intro-card{justify-self:stretch}
  .intro-brand{margin-bottom:24px}
  .intro-logo{width:78px;height:78px;font-size:24px}
  .intro-brand-text{font-size:20px}
  .intro-title{font-size:clamp(38px,10vw,62px)}
}
@media(max-width:560px){
  .intro-splash{align-items:flex-start;padding-top:88px}
  .intro-content{width:92vw}
  .intro-brand{gap:14px;margin-bottom:22px}
  .intro-logo{width:66px;height:66px;font-size:21px}
  .intro-brand-text{font-size:17px;padding-left:12px}
  .intro-kicker{font-size:12px;letter-spacing:3px}
  .intro-title{font-size:42px;letter-spacing:-1.5px}
  .intro-sub{font-size:16px}
  .intro-card{display:none}
  .intro-pill{font-size:10px;padding:9px 11px}
}


/* v57 laptop desktop header fit */
@media(min-width:1181px){
  .topbar{
    display:grid!important;
    grid-template-columns:minmax(0,1fr) minmax(320px,520px) auto!important;
    align-items:center!important;
    gap:16px!important;
    min-height:74px!important;
    padding:10px 18px!important;
  }
  .brand-cluster{
    min-width:0!important;
    gap:12px!important;
    max-width:none!important;
  }
  .logo{
    width:56px!important;
    height:56px!important;
    flex:0 0 56px!important;
    font-size:16px!important;
    border-radius:8px!important;
  }
  .brand-copy{
    min-width:0!important;
    max-width:none!important;
  }
  .kicker{
    font-size:10px!important;
    letter-spacing:2px!important;
    line-height:1!important;
    margin-bottom:4px!important;
    white-space:nowrap!important;
  }
  .title{
    font-size:clamp(24px,1.95vw,32px)!important;
    line-height:1.02!important;
    letter-spacing:-.6px!important;
    white-space:nowrap!important;
    overflow:hidden!important;
    text-overflow:ellipsis!important;
    max-width:720px!important;
  }
  .toolbar{
    display:flex!important;
    align-items:center!important;
    justify-content:flex-end!important;
    gap:10px!important;
    min-width:0!important;
  }
  .toolbar-search{
    width:min(520px,31vw)!important;
    min-width:300px!important;
    height:48px!important;
  }
  .filter-btn{
    height:48px!important;
    padding:0 24px!important;
    border-radius:18px!important;
    font-size:17px!important;
  }
  .status-chip{
    display:none!important;
  }
}
@media(min-width:1181px) and (max-width:1450px){
  .topbar{
    grid-template-columns:minmax(0,1fr) minmax(260px,390px) auto!important;
    gap:12px!important;
  }
  .title{
    font-size:clamp(22px,1.75vw,28px)!important;
    max-width:560px!important;
  }
  .toolbar-search{
    width:min(390px,28vw)!important;
    min-width:250px!important;
  }
  .filter-btn{
    padding:0 20px!important;
  }
}
@media(min-width:1181px) and (max-width:1280px){
  .logo{
    width:52px!important;
    height:52px!important;
    flex-basis:52px!important;
  }
  .kicker{
    font-size:9px!important;
  }
  .title{
    font-size:24px!important;
    max-width:500px!important;
  }
  .toolbar-search{
    width:320px!important;
    min-width:230px!important;
  }
  .filter-btn{
    height:46px!important;
    padding:0 18px!important;
    font-size:16px!important;
  }
}


/* v59 simplified image splash */
.intro-splash{position:fixed;inset:0;z-index:5000;display:flex;align-items:center;justify-content:center;padding:24px;background:radial-gradient(circle at top,rgba(255,223,0,.10),transparent 24%),radial-gradient(circle at bottom,rgba(35,130,145,.10),transparent 26%),#050b16;transition:opacity .55s ease,visibility .55s ease;overflow:hidden}
.intro-splash.hide{opacity:0;visibility:hidden;pointer-events:none}
.intro-simple-wrap{width:min(1320px,92vw);max-height:88vh;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:16px}
.intro-simple-card{width:100%;background:rgba(8,16,29,.82);border:1px solid rgba(255,255,255,.10);border-radius:26px;overflow:hidden;box-shadow:0 28px 90px rgba(0,0,0,.44),0 0 0 1px rgba(255,223,0,.04) inset}
.intro-simple-card picture,.intro-simple-card img{display:block;width:100%;height:auto}
.intro-simple-card img{max-height:80vh;object-fit:contain;background:#06101d}
.intro-simple-progress{width:min(420px,72vw);height:6px;border-radius:999px;background:rgba(255,255,255,.12);overflow:hidden;box-shadow:0 0 0 1px rgba(255,255,255,.05) inset}
.intro-simple-progress span{display:block;height:100%;width:0;background:linear-gradient(90deg,#FFDF00,#238291);animation:introLoad 2.7s ease forwards}
@media(max-width:1024px){
  .intro-simple-wrap{width:min(94vw,980px);max-height:86vh}
}
@media(max-width:768px){
  .intro-splash{padding:16px}
  .intro-simple-wrap{width:100%;max-height:none;gap:12px}
  .intro-simple-card{border-radius:22px}
  .intro-simple-card img{max-height:78vh}
  .intro-simple-progress{width:64vw}
}

/* v60 desktop/laptop density pass */
@media(min-width:1025px){
  .topbar{
    min-height:64px!important;
    padding:9px 16px!important;
    gap:14px!important;
  }
  .logo{
    width:50px!important;
    height:50px!important;
    flex:0 0 50px!important;
    font-size:15px!important;
  }
  .brand-cluster{
    gap:12px!important;
    min-width:0!important;
  }
  .kicker{
    font-size:9px!important;
    letter-spacing:1.8px!important;
    margin-bottom:3px!important;
  }
  .title{
    font-size:clamp(21px,1.55vw,28px)!important;
    line-height:1.02!important;
    max-width:560px!important;
    white-space:nowrap!important;
    overflow:hidden!important;
    text-overflow:ellipsis!important;
  }
  .toolbar-search{
    height:44px!important;
    width:min(390px,30vw)!important;
