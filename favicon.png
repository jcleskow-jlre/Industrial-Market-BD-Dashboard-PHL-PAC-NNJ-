/* v38 comp economics trend charts */
.ai-chart-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:18px}
.ai-chart-card{border:1px solid rgba(255,255,255,.10);border-radius:22px;background:linear-gradient(180deg,rgba(20,27,48,.98),rgba(12,18,33,.98));padding:18px;min-width:0}
.ai-chart-card h4{margin:0 0 6px;font-size:22px;color:#fff}
.ai-chart-card p{margin:0 0 12px;color:#aebad1;font-size:13px;line-height:1.4}
.ai-svg-wrap{width:100%;overflow:hidden}
.ai-legend{display:flex;gap:14px;flex-wrap:wrap;margin-top:8px}
.ai-legend span{display:inline-flex;align-items:center;gap:6px;color:#aebad1;font-size:12px}
.ai-legend i{display:inline-block;width:12px;height:3px;border-radius:2px}
