  }
  .wrap{
    grid-template-columns:240px minmax(0,1fr)!important;
  }
  .kpi{
    min-height:98px!important;
    padding:14px 16px!important;
  }
  .kpi .value{
    font-size:clamp(30px,2.7vw,40px)!important;
  }
  .map-card{
    height:min(500px,calc(100vh - 220px))!important;
  }
}


/* v61 final density + wrapped desktop header */
@media(min-width:1025px){
  .title{
    white-space:normal!important;
    overflow:visible!important;
    text-overflow:clip!important;
    max-width:min(700px,46vw)!important;
    line-height:1.02!important;
  }
}
@media(min-width:1401px){
  .title{
    max-width:min(760px,50vw)!important;
    font-size:clamp(22px,1.45vw,28px)!important;
  }
}

/* v64 Market AI top summary cards */
.ai-market-summary-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:16px;margin-bottom:18px}
.ai-market-summary-card{border:1px solid rgba(255,255,255,.10);border-radius:22px;background:linear-gradient(180deg,rgba(20,27,48,.98),rgba(12,18,33,.98));padding:18px;box-shadow:0 12px 34px rgba(0,0,0,.18);min-width:0}
.ai-market-summary-card h3{margin:0 0 12px;font-size:24px;line-height:1.1;color:#fff;letter-spacing:-.2px}
.ai-market-summary-card .summary-metrics{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px}
.ai-market-summary-card .summary-metric{border:1px solid rgba(255,255,255,.08);background:rgba(255,255,255,.035);border-radius:14px;padding:12px;min-width:0}
.ai-market-summary-card .summary-metric span{display:block;font-size:9px;letter-spacing:1.1px;text-transform:uppercase;color:#9aa8c0;font-weight:900;line-height:1.2}
.ai-market-summary-card .summary-metric strong{display:block;margin-top:6px;font-size:21px;color:#fff;line-height:1.05;white-space:nowrap}
.ai-market-summary-card .summary-note{margin-top:10px;color:#8f9db7;font-size:12px;line-height:1.35}
.ai-market-summary-card .summary-bar{height:7px;border-radius:999px;background:rgba(255,255,255,.08);overflow:hidden;margin-top:12px}
.ai-market-summary-card .summary-bar i{display:block;height:100%;border-radius:999px;background:linear-gradient(90deg,#FFDF00,#238291)}
@media(max-width:1180px){.ai-market-summary-grid{grid-template-columns:1fr}.ai-market-summary-card .summary-metrics{grid-template-columns:repeat(3,minmax(0,1fr))}}
@media(max-width:760px){.ai-market-summary-grid{grid-template-columns:1fr!important;gap:12px}.ai-market-summary-card{padding:14px!important;border-radius:18px!important}.ai-market-summary-card h3{font-size:21px}.ai-market-summary-card .summary-metrics{grid-template-columns:1fr!important}.ai-market-summary-card .summary-metric strong{font-size:22px}}


/* v65 Market AI summary layout QA */
.ai-market-summary-grid{
  display:grid!important;
  grid-template-columns:repeat(3,minmax(0,1fr))!important;
  gap:14px!important;
  margin-bottom:18px!important;
}
.ai-market-summary-card{
  border:1px solid rgba(255,255,255,.10)!important;
  border-radius:22px!important;
  background:linear-gradient(180deg,rgba(20,27,48,.98),rgba(12,18,33,.98))!important;
  padding:16px!important;
  box-shadow:0 12px 34px rgba(0,0,0,.18)!important;
  min-width:0!important;
  overflow:hidden!important;
}
.ai-market-summary-card h3{
  margin:0 0 12px!important;
  font-size:clamp(20px,1.55vw,25px)!important;
  line-height:1.08!important;
  color:#fff!important;
  letter-spacing:-.2px!important;
}
.ai-market-summary-card .summary-metrics{
  display:grid!important;
  grid-template-columns:1fr!important;
  gap:8px!important;
}
.ai-market-summary-card .summary-metric{
  display:grid!important;
  grid-template-columns:1fr auto!important;
  gap:10px!important;
  align-items:center!important;
  border:1px solid rgba(255,255,255,.08)!important;
  background:rgba(255,255,255,.035)!important;
  border-radius:13px!important;
  padding:10px 12px!important;
  min-width:0!important;
}
.ai-market-summary-card .summary-metric span{
  display:block!important;
  font-size:9px!important;
  letter-spacing:1.05px!important;
  text-transform:uppercase!important;
  color:#9aa8c0!important;
  font-weight:900!important;
  line-height:1.2!important;
}
.ai-market-summary-card .summary-metric strong{
  display:block!important;
  margin:0!important;
  font-size:clamp(18px,1.5vw,23px)!important;
  color:#fff!important;
  line-height:1.05!important;
  white-space:nowrap!important;
  text-align:right!important;
}
.ai-market-summary-card .summary-note{
  margin-top:10px!important;
  color:#8f9db7!important;
  font-size:11px!important;
  line-height:1.35!important;
}
.ai-market-summary-card .summary-bar{
  height:7px!important;
  border-radius:999px!important;
  background:rgba(255,255,255,.08)!important;
  overflow:hidden!important;
  margin-top:12px!important;
}
.ai-market-summary-card .summary-bar i{
  display:block!important;
  height:100%!important;
  border-radius:999px!important;
  background:linear-gradient(90deg,#FFDF00,#238291)!important;
}
@media(max-width:1180px){
  .ai-market-summary-grid{
    grid-template-columns:1fr!important;
  }
  .ai-market-summary-card{
    padding:16px!important;
  }
  .ai-market-summary-card .summary-metrics{
    grid-template-columns:repeat(3,minmax(0,1fr))!important;
  }
  .ai-market-summary-card .summary-metric{
    display:block!important;
    padding:10px!important;
  }
  .ai-market-summary-card .summary-metric strong{
    margin-top:5px!important;
    text-align:left!important;
    font-size:22px!important;
  }
}
@media(max-width:760px){
  .ai-market-summary-grid{
    grid-template-columns:1fr!important;
    gap:12px!important;
  }
  .cards .ai-market-summary-card{
    padding:14px!important;
  }
  .cards .ai-market-summary-card .summary-metrics{
    grid-template-columns:1fr!important;
  }
  .cards .ai-market-summary-card .summary-metric{
    display:grid!important;
    grid-template-columns:1fr auto!important;
    padding:10px 12px!important;
  }
  .cards .ai-market-summary-card .summary-metric strong{
    margin:0!important;
    text-align:right!important;
    font-size:20px!important;
  }
}


/* v66 mobile lease-event landlord + Leaflet attribution fix */
@media(max-width:760px){
  .leaflet-control-attribution{
    display:none!important;
  }
}


/* v67 recent comp / size-band analysis */
.ai-size-section{margin-top:18px}
.ai-size-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
.ai-size-card{border:1px solid rgba(255,255,255,.10);border-radius:20px;background:linear-gradient(180deg,rgba(20,27,48,.98),rgba(12,18,33,.98));padding:16px;min-width:0}
.ai-size-card h4{margin:0 0 8px;font-size:22px;line-height:1.1;color:#fff}
.ai-size-card p{margin:0 0 14px;color:#aebad1;font-size:13px;line-height:1.4}
.ai-size-rows{display:grid;gap:13px}
.ai-size-row{display:grid;gap:6px}
.ai-size-top{display:flex;justify-content:space-between;gap:10px;align-items:baseline}
.ai-size-top span{color:#f2f6ff;font-size:13px;font-weight:900}
.ai-size-top strong{color:#fff;font-size:18px;white-space:nowrap}
.ai-size-bar{height:10px;border-radius:999px;background:rgba(255,255,255,.09);overflow:hidden}
.ai-size-bar i{display:block;height:100%;border-radius:999px}
.ai-size-bar i.sizebar-0{background:linear-gradient(90deg,#FFDF00,#F2C300)}
.ai-size-bar i.sizebar-1{background:linear-gradient(90deg,#238291,#52C3D6)}
.ai-size-bar i.sizebar-2{background:linear-gradient(90deg,#A6E05F,#6BBF59)}
.ai-size-sub{color:#8f9db7;font-size:11px;line-height:1.3}
@media(max-width:1180px){.ai-size-grid{grid-template-columns:1fr}}
@media(max-width:760px){.cards .ai-size-grid{grid-template-columns:1fr!important}.cards .ai-size-card{padding:14px!important}}


/* v69 historical asking rent vs comp rent */
.ai-historical-section{margin-top:18px}
.ai-trend-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:14px}
.ai-trend-card{border:1px solid rgba(255,255,255,.10);border-radius:20px;background:linear-gradient(180deg,rgba(20,27,48,.98),rgba(12,18,33,.98));padding:16px;min-width:0}
.ai-trend-card h4{margin:0 0 10px;font-size:21px;line-height:1.1;color:#fff}
.ai-trend-legend{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:12px;color:#aebad1;font-size:11px}
.ai-trend-legend span{display:inline-flex;align-items:center;gap:6px}
.ai-trend-legend i{display:block;width:12px;height:4px;border-radius:999px}
.ai-trend-legend i.ask{background:#FFDF00}
.ai-trend-legend i.comp{background:#52C3D6}
.ai-trend-rows{display:grid;gap:10px}
.ai-trend-row{display:grid;grid-template-columns:42px minmax(0,1fr) 54px;gap:8px;align-items:center}
.ai-trend-year{font-size:12px;color:#dce5f7;font-weight:900}
.ai-trend-bars{display:grid;gap:5px}
.ai-trend-bar{height:16px;position:relative;border-radius:999px;background:rgba(255,255,255,.08);overflow:hidden}
.ai-trend-bar span{display:block;height:100%;border-radius:999px}
.ai-trend-bar.ask span{background:linear-gradient(90deg,#FFDF00,#E8C900)}
.ai-trend-bar.comp span{background:linear-gradient(90deg,#52C3D6,#238291)}
.ai-trend-bar b{position:absolute;right:7px;top:50%;transform:translateY(-50%);font-size:9px;color:#f8fbff;text-shadow:0 1px 3px rgba(0,0,0,.55)}
.ai-trend-count{font-size:10px;color:#8f9db7;line-height:1.15;text-align:right}
@media(max-width:1180px){.ai-trend-grid{grid-template-columns:1fr}}
@media(max-width:760px){.cards .ai-trend-grid{grid-template-columns:1fr!important}.cards .ai-trend-card{padding:14px!important}.ai-trend-row{grid-template-columns:38px minmax(0,1fr) 48px}}


/* v71 standardized comp rent escalation */
.table td{vertical-align:middle}
.table td.rent{white-space:nowrap}


/* v72 comp table filters and formatting cleanup */
.comp-filter-bar{
  display:grid;
  grid-template-columns:repeat(3,minmax(0,1fr)) auto;
  gap:10px;
  padding:12px 14px;
  border-bottom:1px solid rgba(255,255,255,.08);
  background:rgba(255,255,255,.025);
  align-items:end;
}
.comp-filter-bar label{
  display:block;
  font-size:9px;
  letter-spacing:1.2px;
  text-transform:uppercase;
  color:#8f9db7;
  font-weight:900;
  margin-bottom:5px;
}
.comp-filter-bar select{
  width:100%;
  height:38px;
  border:1px solid rgba(255,255,255,.10);
  border-radius:10px;
  background:#151c31;
  color:#f4f7ff;
  padding:0 10px;
  font-size:12px;
  outline:none;
}
.comp-filter-bar button{
  height:38px;
  border:1px solid rgba(255,255,255,.12);
  border-radius:10px;
  background:rgba(255,255,255,.04);
  color:#d7dfef;
  font-weight:900;
  font-size:12px;
  padding:0 12px;
}
@media(max-width:900px){
  .comp-filter-bar{grid-template-columns:1fr 1fr}
}
@media(max-width:760px){
  .comp-filter-bar{display:none}
}


/* v73 expanded comp filters */
.comp-filter-bar.expanded{
  grid-template-columns:minmax(220px,1.35fr) minmax(150px,.8fr) minmax(150px,.8fr) minmax(150px,.8fr) auto;
}
.comp-filter-bar input{
  width:100%;
  height:38px;
  border:1px solid rgba(255,255,255,.10);
  border-radius:10px;
  background:#151c31;
  color:#f4f7ff;
  padding:0 10px;
  font-size:12px;
  outline:none;
}
.comp-filter-bar input::placeholder{color:#7f8ca6}
.comp-filter-bar .wide{min-width:0}
@media(max-width:1180px){
  .comp-filter-bar.expanded{grid-template-columns:1fr 1fr 1fr}
  .comp-filter-bar.expanded button{grid-column:auto}
}
@media(max-width:900px){
  .comp-filter-bar.expanded{grid-template-columns:1fr 1fr}
  .comp-filter-bar.expanded .wide{grid-column:1 / -1}
}
@media(max-width:760px){
  .comp-filter-bar.expanded{display:none}
}


/* v74 top KPI gauge update */
.leverage-kpi .gauge-wrap{
  position:relative;
  z-index:1;
  display:grid;
  grid-template-columns:82px 1fr;
  gap:12px;
  align-items:center;
  margin-top:8px;
}
.gauge{
  --gauge-color:#ffdf00;
  position:relative;
  width:82px;
  height:46px;
  overflow:hidden;
}
.gauge:before{
  content:"";
  position:absolute;
  left:0;
  top:0;
  width:82px;
  height:82px;
  border-radius:50%;
  background:conic-gradient(from 270deg,#2ec27e 0deg,#8fe08a 50deg,#ffdf00 90deg,#f2b45e 135deg,#d94a4a 180deg,transparent 180deg,transparent 360deg);
}
.gauge:after{
  content:"";
  position:absolute;
  left:10px;
  top:10px;
  width:62px;
  height:62px;
  border-radius:50%;
  background:#11182c;
}
.gauge-fill{
  position:absolute;
  left:39px;
  bottom:3px;
  width:4px;
  height:36px;
  border-radius:999px;
  background:var(--gauge-color);
  transform-origin:50% 100%;
  transform:rotate(90deg);
  z-index:2;
  box-shadow:0 0 10px rgba(255,255,255,.25);
}
.gauge-center{
  position:absolute;
  left:0;
  right:0;
  bottom:0;
  z-index:3;
  display:flex;
  align-items:baseline;
  justify-content:center;
  gap:2px;
}
.gauge-center strong{
  font-size:21px;
  line-height:1;
}
.gauge-center span{
  font-size:10px;
  color:#9aa8c0;
  font-weight:900;
}
.gauge-copy div{
  color:#fff;
  font-size:13px;
  line-height:1.15;
  font-weight:950;
}
.gauge-copy small{
  display:block;
  margin-top:4px;
  color:#8f9db7;
  font-size:9px;
  line-height:1.25;
  font-weight:800;
}
@media(max-width:1400px){
  .leverage-kpi .gauge-wrap{grid-template-columns:70px 1fr;gap:9px}
  .gauge{width:70px;height:40px}
  .gauge:before{width:70px;height:70px}
  .gauge:after{left:9px;top:9px;width:52px;height:52px}
  .gauge-fill{left:33px;height:31px}
  .gauge-center strong{font-size:18px}
  .gauge-copy div{font-size:12px}
}
@media(max-width:760px){
  .leverage-kpi .gauge-wrap{grid-template-columns:58px 1fr;gap:8px;margin-top:5px}
  .gauge{width:58px;height:34px}
  .gauge:before{width:58px;height:58px}
  .gauge:after{left:8px;top:8px;width:42px;height:42px}
  .gauge-fill{left:27px;height:26px}
  .gauge-center strong{font-size:15px}
  .gauge-center span{font-size:8px}
  .gauge-copy div{font-size:10px}
  .gauge-copy small{display:none}
}


/* v75 gauge + comp filter + map overlay cleanup */
.map-stats{
  display:none!important;
}
@media(max-width:760px){
  .cards .comp-filter-bar,
  .cards .comp-filter-bar.expanded{
    display:grid!important;
    grid-template-columns:1fr!important;
    gap:10px!important;
    padding:14px!important;
    margin:0 0 12px!important;
    border:1px solid rgba(255,255,255,.10)!important;
    border-radius:18px!important;
    background:rgba(255,255,255,.035)!important;
  }
  .cards .comp-filter-bar.expanded .wide{
    grid-column:auto!important;
  }
  .cards .comp-filter-bar input,
  .cards .comp-filter-bar select,
  .cards .comp-filter-bar button{
    height:46px!important;
    font-size:15px!important;
  }
  .leverage-kpi .gauge-wrap{
    grid-template-columns:64px 1fr!important;
  }
  .gauge{
    width:64px!important;
    height:38px!important;
  }
  .gauge:before{
    width:64px!important;
    height:64px!important;
  }
  .gauge:after{
    left:8px!important;
    top:8px!important;
    width:48px!important;
    height:48px!important;
  }
  .gauge-fill{
    left:30px!important;
    height:29px!important;
  }
}


/* v87 profile cleanup */
.detail-section h4{
  letter-spacing:2px;
}
.detail-section:last-of-type h4{
  color:#8f9db7;
}
.detail-section:last-of-type .v{
  color:#a8b3c8;
  font-size:13px;
}


/* v88 profile label emphasis + owner table runtime backfill */
.detail-section .k,
.comp-mini-k{
  color:#FFDF00!important;
  font-weight:950!important;
  letter-spacing:1.5px!important;
}
.detail-section .v,
.comp-mini-v{
  font-weight:750!important;
}
.detail-section h4{
  color:#FFDF00!important;
  font-weight:950!important;
  letter-spacing:2.4px!important;
  border-bottom:1px solid rgba(255,223,0,.18);
  padding-bottom:8px;
  margin-bottom:14px!important;
}
.detail-section .meta{
  row-gap:14px!important;
}
.detail-section:last-of-type h4{
  color:#9aa8c0!important;
  border-bottom-color:rgba(255,255,255,.10);
}
.detail-section:last-of-type .k{
  color:#8f9db7!important;
}
.detail-section:last-of-type .v{
  color:#aeb9ce!important;
}

</style>
</head>
<body class="auth-locked">
<div aria-modal="true" class="auth-gate" id="authGate" role="dialog">
<div class="auth-card">
<div class="auth-logo">savills</div>
<h1>Industrial Market Intelligence</h1>
<p>Enter the dashboard password to continue. Your access remains active in this browser for 2 hours, including normal page refreshes.</p>
<div class="auth-field">
<label for="dashboardPassword">Password</label>
<input autocomplete="current-password" id="dashboardPassword" placeholder="Enter password" type="password"/>
</div>
<button class="auth-btn" id="authSubmit">Open dashboard</button>
<div class="auth-error" id="authError">Incorrect password. Please try again.</div>
<div class="auth-note">For security, the dashboard will ask again after 2 hours.</div>
</div>
</div>
<!-- splash removed in v92 lightweight build -->

<div class="app">
<header class="topbar">
<div class="brand-cluster">
<div class="logo">savills</div>
<div class="brand-copy">
<div class="kicker">Industrial Advisory</div>
<div class="title">Industrial Market Intelligence &amp; BD Dashboard (PHL-PAC-NNJ)</div>
</div>
</div>
<nav class="topnav">
<button class="nav-link active" data-side-tab="buildings">Building inventory</button>
<button class="nav-link" data-side-tab="events">Lease events</button>
<button class="nav-link" data-side-tab="comps">Comps</button>
<button class="nav-link" data-side-tab="rents">Market AI insights</button>
</nav>
<div class="toolbar">
<div class="toolbar-search"><span>⌕</span><input id="quickSearch" placeholder="Search buildings, owners, tenants, deals..."/></div>
<div class="status-chip">Market intelligence dashboard</div>
<button class="filter-btn" id="filterBtn">Filters</button>
</div>
</header>
<div class="drawer-backdrop" id="backdrop"></div>
<div class="wrap">
<aside class="filters" id="filters"><button class="filter-close" id="filterCloseBtn">Close filters</button>
<div class="sidebar-header"><div class="sidebar-title">Dashboard controls</div><div class="sidebar-note">Filter the dashboard by market, submarket, timing, priority and size.</div></div><div class="sidebar-caption">Views</div>
<div class="nav-stack">
<button class="sidebar-link active" data-side-tab="buildings">Building inventory</button>
<button class="sidebar-link" data-side-tab="events">Lease events</button>
<button class="sidebar-link" data-side-tab="comps">Comps</button>
<button class="sidebar-link" data-side-tab="rents">Market AI insights</button>
</div>
<h3>Search and filters</h3>
<div class="field"><label>Search tenant / address</label><input id="search" placeholder="Search tenant, address, city, landlord..."/></div>
<div class="field"><label>Dataset focus</label><select id="focus"><option value="buildings">Building inventory</option><option value="events">Lease events</option><option value="comps">Lease comps</option><option value="rents">Market AI insights</option></select></div>
<div class="field"><label>Region / focus</label><select id="region"><option value="">All regions</option></select></div>
<div class="field"><label>Submarket</label><select id="submarket"><option value="">All</option></select></div>
<div class="field"><label>Expiration window</label><select id="expiration"><option value="">All</option></select></div>
<div class="field"><label>BD priority</label><select id="priority"><option value="">All</option></select></div>
<div class="field"><label>Minimum SF</label><select id="minsf"><option value="0">All sizes</option><option value="50000">50k+ SF</option><option value="100000">100k+ SF</option><option value="200000">200k+ SF</option><option value="500000">500k+ SF</option></select></div>
<button class="reset" id="resetBtn">Reset filters</button>
</aside>
<main class="main"><div class="kpis"><div class="kpi"><div class="label">BD lease events</div><div class="value" id="k-events">—</div><div class="sub" id="k-events-sub">—</div></div><div class="kpi"><div class="label">Total inventory</div><div class="value" id="k-inventory-msf">—</div><div class="sub" id="k-buildings-sub">—</div></div><div class="kpi"><div class="label">Comps in database</div><div class="value" id="k-comps">—</div><div class="sub" id="k-comps-sub">—</div></div><div class="kpi leverage-kpi"><div class="label">Landlord leverage score</div><div class="gauge-wrap"><div class="gauge" id="k-leverage-gauge"><div class="gauge-fill" id="k-leverage-fill"></div><div class="gauge-center"><strong id="k-leverage-score">—</strong><span>/100</span></div></div><div class="gauge-copy"><div id="k-leverage-label">—</div><small id="k-leverage-sub">—</small></div></div></div></div>
<section class="map-card"><div class="map" id="map"></div><div class="map-options"><button id="mapOptBtn">⌄ Map options</button><div class="map-menu" id="mapMenu"><div class="field"><label>Map layer</label><div class="pill-row"><button class="pill active" data-layer="buildings">Buildings</button><button class="pill" data-layer="events">Lease events</button><button class="pill" data-layer="comps">Comps</button></div></div></div></div><div class="map-stats"><div class="map-stat primary"><span>Map view records</span><strong id="m-count">0</strong></div><div class="map-stat"><span>High priority</span><strong id="m-priority">0</strong></div><div class="map-stat"><span>0–36 mo. exp.</span><strong id="m-window">0</strong></div><div class="map-stat"><span>SF in view</span><strong id="m-sf">0</strong></div></div></section>
<div class="mobile-intro">Use filters and sorting to focus the market view.</div>
<div class="mobile-controls" id="mobileControls">
<button class="mobile-control-btn" id="mobileFilterBtn">Filters</button>
<div class="mobile-sort">
<label>Sort</label>
<select id="mobileSort">
<option value="">Default</option>
</select>
<button class="mobile-control-btn secondary" id="mobileSortDir">Desc</button>
</div>
</div>
<section class="data-card"><div class="tabs"><button class="tab active" data-tab="buildings">Building inventory</button><button class="tab" data-tab="comps">Comps</button><button class="tab" data-tab="events">Lease events</button><button class="tab" data-tab="rents">Market AI insights</button></div><div class="section-head"><h2 id="sectionTitle">Building inventory</h2><p id="sectionSub">—</p></div><div class="table-wrap" id="tableWrap"></div><div class="cards" id="cards"></div></section>
</main>
</div>
</div>
<aside class="detail" id="detail"><div class="detail-head"><button id="detailClose">Close</button><div class="detail-title" id="detailTitle">Record</div><div class="detail-sub" id="detailSub"></div></div><div class="detail-body" id="detailBody"></div></aside><div class="toast" id="toast">Copied</div>




<script src="data/market_rents.js?v=95"></script><script src="data/bd_opportunities.js?v=95"></script><script src="data/comps.js?v=95"></script><script src="data/buildings.js?v=95"></script><script>
(function(){
'use strict';
const $=id=>document.getElementById(id); const arr=v=>Array.isArray(v)?v:[];
const BUILDINGS_SAFE=arr((typeof BUILDINGS!=='undefined'?BUILDINGS:window.BUILDINGS)||[]); const COMPS_SAFE=arr((typeof COMPS!=='undefined'?COMPS:window.COMPS)||[]); const EVENTS_SAFE=arr((typeof BD_OPPORTUNITIES!=='undefined'?BD_OPPORTUNITIES:window.BD_OPPORTUNITIES)||[]); const RENT_REGIONS=((((typeof MARKET_RENTS!=='undefined'?MARKET_RENTS:window.MARKET_RENTS)||{}).regions)||[]); const byId=new Map(BUILDINGS_SAFE.map(b=>[b.BuildingID,b])); let activeTab='buildings'; let mapLayer='buildings'; let current=[]; let sortState={tab:'',key:'',dir:'asc'}; let compFilterState={q:'',submarket:'',leaseType:'',size:''}; let map=null; let markers=null; let labelLayer=null; let referenceLabels=null;
function fmt(n){n=Number(n)||0;return n.toLocaleString()} 
function msf(n){
  n=Number(n)||0;
  if(!n)return '—';
  return (n/1e6).toLocaleString(undefined,{maximumFractionDigits:0})+' MSF';
}
function clamp(n,min,max){return Math.max(min,Math.min(max,n));}
function avgRecentCompRentAll(){
  const rows=COMPS_SAFE.filter(c=>isRecentComp(c,12));
  const vals=rows.map(c=>compRentForAnalysis(c)).filter(v=>v!==null&&v>0);
  if(!vals.length)return null;
  return vals.reduce((a,b)=>a+b,0)/vals.length;
}
function avgSavillsRentAll(){
  const data=marketInsightData();
  const vals=['NNJ','PA I-81/78','PHL/SNJ'].map(k=>data[k]&&toNum(data[k].savills_rent)).filter(v=>v!==null&&v>0);
  if(!vals.length)return null;
  return vals.reduce((a,b)=>a+b,0)/vals.length;
}
function avgVacancyAll(){
  const data=marketInsightData();
  const vals=['NNJ','PA I-81/78','PHL/SNJ'].map(k=>data[k]&&toNum(data[k].savills_vac)).filter(v=>v!==null&&v>0);
  if(!vals.length)return null;
  return vals.reduce((a,b)=>a+b,0)/vals.length;
}
function leverageScore(rba,available,vacant){
  const avgVac=avgVacancyAll();
  const avgComp=avgRecentCompRentAll();
  const avgAsk=avgSavillsRentAll();
  const availabilityRate=rba?available/rba*100:null;
  const directVacancyRate=rba?vacant/rba*100:null;
  let score=50;
  // Higher vacancy/availability generally improves tenant leverage, so it lowers landlord leverage.
  if(avgVac!==null) score += (8.0-avgVac)*4.0;
  if(availabilityRate!==null) score += (10.0-availabilityRate)*1.15;
  if(directVacancyRate!==null) score += (7.0-directVacancyRate)*1.3;
  // Recent comp rents below asking-rent benchmarks indicate tenant leverage; above asking indicates landlord leverage.
  if(avgComp!==null&&avgAsk!==null&&avgAsk>0){
    const spreadPct=(avgComp-avgAsk)/avgAsk*100;
    score += spreadPct*0.95;
  }
  return Math.round(clamp(score,1,100));
}
function leverageLabel(score){
  if(score>=75)return 'Strong landlord leverage';
  if(score>=58)return 'Moderate landlord leverage';
  if(score>=43)return 'Balanced market';
  if(score>=25)return 'Moderate tenant leverage';
  return 'Strong tenant leverage';
}
function leverageColor(score){
  if(score>=75)return '#d94a4a';
  if(score>=58)return '#f2b45e';
  if(score>=43)return '#ffdf00';
  if(score>=25)return '#8fe08a';
  return '#2ec27e';
}

function sf(n){n=Number(n)||0;if(!n)return '—'; if(n>=1e9)return (n/1e9).toFixed(2)+' BSF'; if(n>=1e6)return (n/1e6).toFixed(n>=1e8?0:1)+' MSF'; if(n>=1000)return Math.round(n/1000)+'K SF'; return fmt(n)+' SF'} function money(n){n=Number(n);return isFinite(n)&&n>0?'$'+n.toFixed(2):'—'} function pct(n){n=Number(n)||0;return n?n.toFixed(1)+'%':'—'}
function val(o,keys){for(const k of keys){if(o&&o[k]!==undefined&&o[k]!==null&&String(o[k]).trim()!=='')return o[k]}return ''} function num(o,keys){return Number(val(o,keys))||0}
function compRentVal(o){return toNum(o.StartingRentPSF)||toNum(o.CompRentPSF)||toNum(o.StartingRent)||toNum(o.RentPSF)||toNum(o.Rent)}
function compNerVal(o){return toNum(o.CalculatedNERPSF)||toNum(o.NetEffectiveRentPSF)||toNum(o.SourceNetEffectiveRentPSF)||toNum(o.NER)||toNum(o.NetEffectiveRent)}
function compTiVal(o){if(o&&Object.prototype.hasOwnProperty.call(o,'TIValuePSFClean'))return toNum(o.TIValuePSFClean); return toNum(o.TIValuePSF)||toNum(o.TIPerSF)||toNum(o.TIAllowancePSF)||toNum(o.TI)}
function compFreeRentVal(o){if(o&&Object.prototype.hasOwnProperty.call(o,'FreeRentMonthsClean'))return toNum(o.FreeRentMonthsClean); return toNum(o.FreeRentMonths)||toNum(o.FreeRent)||toNum(o.AbatementMonths)}
function sameTenant(a,b){a=String(a||'').toLowerCase().replace(/[^a-z0-9]/g,''); b=String(b||'').toLowerCase().replace(/[^a-z0-9]/g,''); return a&&b&&(a===b||a.includes(b)||b.includes(a));}
function latestCompFor(o){
  const addr=String(o.StreetAddress||'').toLowerCase().trim();
  const city=String(o.City||'').toLowerCase().trim();
  const tenant=String(o.Tenant||'').toLowerCase().trim();
  const set=COMPS_SAFE.filter(c=>{
    const hasRent=toNum(c.StartingRentPSF)!==null||toNum(c.NetEffectiveRentPSF)!==null||toNum(c.EstimatedStartingRentTodayPSF)!==null;
    if(!hasRent)return false;
    const caddr=String(c.StreetAddress||'').toLowerCase().trim();
    const ccity=String(c.City||'').toLowerCase().trim();
    return (o.BuildingID&&c.BuildingID===o.BuildingID)
      || (addr&&caddr&&addr===caddr&&(!city||!ccity||city===ccity))
      || (sameTenant(c.Tenant,o.Tenant)&&addr&&caddr&&addr===caddr);
  });
  set.sort((a,b)=>String(b.ExecutionDate||b.CommencementDate||'').localeCompare(String(a.ExecutionDate||a.CommencementDate||'')));
  return set[0]||null;
}
function marketRentFor(o){
  let v=toNum(o.MarketBenchmarkPSF)||toNum(o.MarketRentPSF)||toNum(o.SavillsMarketRentPSF)||toNum(o.SavillsBenchmarkPSF);
  if(v!==null&&v>0)return v;
  const b=byId.get(o.BuildingID)||{};
  v=toNum(b.MarketBenchmarkPSF)||toNum(b.MarketRentPSF)||toNum(b.SavillsMarketRentPSF)||toNum(b.SavillsBenchmarkPSF);
  if(v!==null&&v>0)return v;
  const keys=[o.Region,o.Market,o.Submarket,b.Region,b.Market,b.Submarket].filter(Boolean).map(x=>String(x).toLowerCase());
  const r=RENT_REGIONS.find(x=>keys.includes(String(x.region||'').toLowerCase())||keys.includes(String(x.label||'').toLowerCase())||keys.includes(String(x.market||'').toLowerCase())||keys.includes(String(x.submarket||'').toLowerCase()));
  v=r?toNum(r.overall_asking_rent||r.savills_market_rent_psf||r.market_rent_psf):null;
  return v!==null&&v>0?v:null;
}

function parseDashboardDate(v){
  if(!v)return null;
  if(v instanceof Date && !isNaN(v))return v;
  const s=String(v).trim();
  if(!s)return null;
  const d=new Date(s);
  if(!isNaN(d))return d;
  const m=s.match(/^(\d{1,2})\/(\d{1,2})\/(\d{2,4})$/);
  if(m){const y=Number(m[3])<100?2000+Number(m[3]):Number(m[3]); return new Date(y,Number(m[1])-1,Number(m[2]));}
  return null;
}
function yearsElapsedFrom(startDate, asOfDate){
  const s=parseDashboardDate(startDate), a=parseDashboardDate(asOfDate)||new Date();
  if(!s||a<s)return 0;
  let years=a.getFullYear()-s.getFullYear();
  if(a.getMonth()<s.getMonth()||(a.getMonth()===s.getMonth()&&a.getDate()<s.getDate()))years--;
  return Math.max(0,years);
}
function monthsElapsedFrom(startDate, asOfDate){
  const s=parseDashboardDate(startDate), a=parseDashboardDate(asOfDate)||new Date();
  if(!s||a<s)return 0;
  let months=(a.getFullYear()-s.getFullYear())*12+(a.getMonth()-s.getMonth());
  if(a.getDate()<s.getDate())months--;
  return Math.max(0,months);
}
function rentScheduleCurrentRent(scheduleText, startRent, commencementDate, asOfDate){
  const text=String(scheduleText||'');
  if(!text||!startRent)return null;
  const monthsElapsed=monthsElapsedFrom(commencementDate, asOfDate);
  const rents=[];
  // Format examples: "Rent Schedule: 3.9/12 months, 4.15/12 months"
  const monthPairs=[...text.matchAll(/\$?\s*(\d+(?:\.\d+)?)\s*\/\s*(\d+)\s*months?/gi)];
  if(monthPairs.length){
    monthPairs.forEach(m=>{
      const rent=Number(m[1]), months=Number(m[2]);
      if(isFinite(rent)&&isFinite(months)&&months>0){for(let i=0;i<months;i++)rents.push(rent);}
    });
    if(rents.length)return rents[Math.min(monthsElapsed,rents.length-1)];
  }
  // Format examples: "$17.50/1y, $18.50/1y"
  const yearPairs=[...text.matchAll(/\$?\s*(\d+(?:\.\d+)?)\s*\/\s*(\d+)\s*y/gi)]
    .filter(m=>!text.slice(Math.max(0,m.index-30),m.index).toLowerCase().includes('percent'));
  if(yearPairs.length){
    yearPairs.forEach(m=>{
      const rent=Number(m[1]), yrs=Number(m[2]);
      if(isFinite(rent)&&isFinite(yrs)&&yrs>0){for(let i=0;i<yrs*12;i++)rents.push(rent);}
    });
    if(rents.length)return rents[Math.min(monthsElapsed,rents.length-1)];
  }
  return null;
}
function escalationPercent(text){
  const s=String(text||'');
  let m=s.match(/([0-9]+(?:\.[0-9]+)?)\s*%\s*(?:per\s*year|\/\s*1y|annually|annual|\/yr)?/i);
  if(!m)m=s.match(/percent\s*=\s*([0-9]+(?:\.[0-9]+)?)\s*%?/i);
  if(m){const pct=Number(m[1]); if(isFinite(pct)&&pct>=0&&pct<20)return pct/100;}
  return null;
}
function escalationDollar(text){
  const s=String(text||'');
  let m=s.match(/(?:bump dollar|bump amount|amount)\s*=?\s*\$?\s*([0-9]+(?:\.[0-9]+)?)/i);
  if(!m)m=s.match(/\$\s*([0-9]+(?:\.[0-9]+)?)\s*(?:annual|per year|\/1y)/i);
  if(m){const amt=Number(m[1]); if(isFinite(amt)&&amt>=0&&amt<=3)return amt;}
  return null;
}
function calculatedCurrentRentForComp(c, asOfDate){
  const start=toNum(c.StartingRentPSF)||toNum(c.CurrentRentPSF)||toNum(c.CompRentPSF);
  if(start===null||start<=0)return null;
  const commencement=c.CommencementDate||c.RentCommencementDate||c.LeaseCommencementDate||c.ExecutionDate;
  if(!parseDashboardDate(commencement))return start;
  const expiration=parseDashboardDate(c.ExpirationDate);
  const asOf=parseDashboardDate(asOfDate)||new Date();
  if(expiration&&asOf>expiration)return null;
  const escText=c.RentEscalationRaw||c.RentEscalation||c.RentSchedule||c.RentEscalationClean||'';
  const scheduled=rentScheduleCurrentRent(escText,start,commencement,asOf);
  if(scheduled!==null&&scheduled>0)return scheduled;
  const yrs=yearsElapsedFrom(commencement,asOf);
  const pct=escalationPercent(escText);
  if(pct!==null)return start*Math.pow(1+pct,yrs);
  const dollar=escalationDollar(escText);
  if(dollar!==null)return start+(dollar*yrs);
  return start;
}
function currentRentFor(o){
  let v=toNum(o.CurrentRentPSF);
  if(v!==null&&v>0)return v;
  if(o&&o.CompEventID){
    v=calculatedCurrentRentForComp(o,new Date());
    return v!==null&&v>0?v:null;
  }
  v=toNum(o.StartingRentPSF)||toNum(o.CompRentPSF)||toNum(o.NetEffectiveRentPSF);
  if(v!==null&&v>0)return v;
  const c=latestCompFor(o);
  v=c?calculatedCurrentRentForComp(c,new Date()):null;
  return v!==null&&v>0?v:null;
}
function rentDeltaFor(o){let v=toNum(o.RentDeltaPSF); if(v!==null)return v; const cur=currentRentFor(o), m=marketRentFor(o); return cur!==null&&m!==null?cur-m:null;}
function rentDeltaPctFor(o){let v=toNum(o.RentDeltaPct); if(v!==null)return v; const d=rentDeltaFor(o), m=marketRentFor(o); return d!==null&&m?d/m:null;}
function rentPositionFor(o){if(o.RentPosition)return o.RentPosition; const d=rentDeltaFor(o); if(d===null)return '—'; return d>0?'Above market':d<0?'Below market':'At market';}

function matchedBuildingFor(o){
  if(!o)return {};
  if(o.BuildingID && byId.has(o.BuildingID))return byId.get(o.BuildingID)||{};
  const addr=String(o.StreetAddress||'').toLowerCase().trim();
  const city=String(o.City||'').toLowerCase().trim();
  if(!addr)return {};
  return BUILDINGS_SAFE.find(b=>{
    const ba=String(b.StreetAddress||'').toLowerCase().trim();
    const bc=String(b.City||'').toLowerCase().trim();
    return ba===addr && (!city||!bc||bc===city);
  })||{};
}
function landlordFor(o){
  const b=matchedBuildingFor(o);
  return o.LandlordOwner||o.OwnerLandlord||o.OwnerName||o.Landlord||o.DeveloperName||o.PropertyManager||o.LeasingCompanyName||o.LeasingCompanyContact||b.OwnerName||b.LandlordOwner||b.OwnerLandlord||b.TrueOwner||b.Owner||b.DeveloperName||b.PropertyManager||b.LeasingCompanyName||b.LeasingCompanyContact||'';
}



function ownerFromAnyField(o){
  if(!o)return '';
  return o.OwnerTableDisplay||o.OwnerLandlordDisplay||o.OwnerDisplay||o.OwnerName||o.LandlordOwner||o.OwnerLandlord||o.Landlord||o.TrueOwner||o.Owner||o.DeveloperName||o.PropertyManager||o.LeasingCompanyName||o.LeasingCompanyContact||'';
}
function normalizeOwnerFieldsRuntime(){
  const ownerById=new Map();
  const ownerByAddr=new Map();
  BUILDINGS_SAFE.forEach(b=>{
    const owner=ownerFromAnyField(b);
    const key=[b.StreetAddress,b.City,b.State].filter(Boolean).join('|').toLowerCase();
    if(owner){
      if(b.BuildingID)ownerById.set(String(b.BuildingID),owner);
      if(key)ownerByAddr.set(key,owner);
    }
  });
  [BUILDINGS_SAFE,EVENTS_SAFE,COMPS_SAFE].forEach(arr=>{
    arr.forEach(r=>{
      let owner=ownerFromAnyField(r);
      const key=[r.StreetAddress,r.City,r.State].filter(Boolean).join('|').toLowerCase();
      if(!owner&&r.BuildingID&&ownerById.has(String(r.BuildingID)))owner=ownerById.get(String(r.BuildingID));
      if(!owner&&key&&ownerByAddr.has(key))owner=ownerByAddr.get(key);
      if(owner){
        r.OwnerTableDisplay=owner;
        r.OwnerLandlordDisplay=owner;
        r.OwnerDisplay=owner;
        r.OwnerName=owner;
        r.LandlordOwner=owner;
        r.OwnerLandlord=owner;
        r.Landlord=owner;
      }
    });
  });
}

function tableOwnerValue(o){
  if(!o)return '';
  return o.OwnerTableDisplay||o.OwnerLandlordDisplay||o.OwnerDisplay||o.OwnerName||o.LandlordOwner||o.OwnerLandlord||o.Landlord||o.DeveloperName||o.PropertyManager||o.LeasingCompanyName||o.LeasingCompanyContact||landlordFor(o)||'';
}

function derivedValue(o,k){if(!o)return ''; if(['OwnerTableDisplay','OwnerLandlordDisplay','OwnerDisplay','OwnerName','LandlordOwner','OwnerLandlord','Landlord'].includes(k))return tableOwnerValue(o); if(['OwnerTableDisplay','OwnerLandlordDisplay','OwnerDisplay','OwnerName','LandlordOwner','OwnerLandlord','Landlord'].includes(k))return tableOwnerValue(o); if(k==='OwnerTableDisplay')return o.OwnerTableDisplay||o.OwnerLandlordDisplay||o.OwnerDisplay||o.OwnerName||o.DeveloperName||o.LeasingCompanyName||''; if(k==='OwnerDisplay'||k==='OwnerLandlordDisplay'||k==='OwnerName'||k==='LandlordOwner'||k==='OwnerLandlord'||k==='Landlord')return o.OwnerLandlordDisplay||o.OwnerDisplay||o.OwnerName||o.LandlordOwner||o.OwnerLandlord||o.Landlord||landlordFor(o); if(k==='CompSubmarketDisplay')return o.CompSubmarketDisplay||''; if(k==='LandlordOwner'||k==='OwnerLandlord'||k==='OwnerName'||k==='Landlord')return o.OwnerLandlordDisplay||o.OwnerDisplay||o.OwnerName||o.LandlordOwner||o.OwnerLandlord||o.Landlord||landlordFor(o); if(k==='CurrentRentPSF'||k==='CalculatedCurrentRentPSF')return currentRentFor(o); if(k==='MarketBenchmarkPSF')return marketRentFor(o); if(k==='RentDeltaPSF')return rentDeltaFor(o); if(k==='RentDeltaPct')return rentDeltaPctFor(o); if(k==='RentPosition')return rentPositionFor(o); if(k==='StartingRentPSF')return compRentVal(o); if(k==='NetEffectiveRentPSF')return compNerVal(o); if(k==='TIValuePSF')return compTiVal(o); if(k==='FreeRentMonths')return compFreeRentVal(o); if(k==='RentTypeClean')return o.RentTypeClean; if(k==='RentEscalationClean')return o.RentEscalationClean; if(k==='FreeRentMonthsClean')return o.FreeRentMonthsClean; if(k==='TIValuePSFClean')return o.TIValuePSFClean; return o[k];}


function showLoadStatus(){
  if(BUILDINGS_SAFE.length||EVENTS_SAFE.length||COMPS_SAFE.length)return;
  const msg='<div class="error"><b>No dashboard data loaded.</b><br>Check that data/buildings.js, data/bd_opportunities.js, data/comps.js, and data/market_rents.js were uploaded to the same folder as dashboard.html.</div>';
  const main=document.querySelector('.main'); if(main)main.insertAdjacentHTML('afterbegin',msg);
}

function init(){showLoadStatus(); normalizeOwnerFieldsRuntime(); populateFilters(); bind(); render(); setTimeout(()=>{try{initMap(); renderMap(); if(map)map.invalidateSize();}catch(e){console.error(e)}},900)}
function populateFilters(){addOpts('region',[...BUILDINGS_SAFE.map(b=>b.Region),...EVENTS_SAFE.map(e=>e.Region),...COMPS_SAFE.map(c=>c.Region)]);addOpts('submarket',[...BUILDINGS_SAFE.map(b=>b.Submarket),...EVENTS_SAFE.map(e=>e.Submarket),...COMPS_SAFE.map(c=>c.Submarket)]);addActiveLeaseOpt();addOpts('expiration',[...EVENTS_SAFE.map(e=>e.ExpirationWindow),...COMPS_SAFE.map(c=>c.ExpirationWindow)]);addOpts('priority',EVENTS_SAFE.map(e=>e.BDPriority));}
function addActiveLeaseOpt(){const el=$('expiration'); if(!el)return; const o=document.createElement('option'); o.value='__active__'; o.textContent='All active leases'; el.appendChild(o);} 
function addOpts(id,values){const el=$(id);[...new Set(values.filter(Boolean).map(String))].sort().forEach(v=>{const o=document.createElement('option');o.value=v;o.textContent=v;el.appendChild(o);});}

function getExpirationDate(o){
  return parseDashboardDate(o.LeaseExpirationDate||o.ExpirationDate||o.Expiration||o.LeaseExpDate);
}
function isActiveLeaseRecord(o){
  const d=getExpirationDate(o);
  const today=new Date(); today.setHours(0,0,0,0);
  if(d){d.setHours(0,0,0,0); return d>=today;}
  const y=toNum(o.ExpirationYear);
  return y!==null ? y>=today.getFullYear() : false;
}
function expirationMatch(o,expiration){
  if(!expiration)return true;
  if(expiration==='__active__')return isActiveLeaseRecord(o);
  return o.ExpirationWindow===expiration;
}


function fullSf(v){
  const n=toNum(v);
  return n===null?'—':Math.round(n).toLocaleString()+' SF';
}
function isSubleaseComp(o){
  const v=o.Sublease;
  if(v===true)return true;
  if(v===false)return false;
  const s=String(v||'').trim().toLowerCase();
  return ['true','yes','y','sublease','1'].includes(s);
}

function compSizeRangeMatch(o,range){
  if(!range)return true;
  const sfv=num(o,['LeaseSF','AggregateLeasedSFOrCompTotal','LeasedSF']);
  if(range==='lt50')return sfv<50000;
  if(range==='50-100')return sfv>=50000&&sfv<100000;
  if(range==='100-150')return sfv>=100000&&sfv<150000;
  if(range==='150-250')return sfv>=150000&&sfv<250000;
  if(range==='250-400')return sfv>=250000&&sfv<400000;
  if(range==='400-500')return sfv>=400000&&sfv<500000;
  if(range==='500-750')return sfv>=500000&&sfv<750000;
  if(range==='750-1000')return sfv>=750000&&sfv<1000000;
  if(range==='1000plus')return sfv>=1000000;
  return true;
}
function compLeaseTypeMatch(o,type){
  if(!type)return true;
  const tx=String(o.TransactionType||o.LeaseType||o.Transaction_Type||'').toLowerCase();
  if(type==='new')return tx.includes('new');
  if(type==='renewal')return tx.includes('renew');
  if(type==='sublease')return isSubleaseComp(o)||tx.includes('sublease');
  if(type==='direct')return !isSubleaseComp(o)&&!tx.includes('sublease');
  return true;
}
function compSearchMatch(o,q){
  if(!q)return true;
  const b=matchedBuildingFor(o)||{};
  const text=[
    o.Tenant,o.PropertyName,o.MatchedPropertyName,o.StreetAddress,o.City,o.State,o.Region,o.Market,o.Submarket,
    o.OwnerLandlord,o.LandlordOwner,o.OwnerName,o.TransactionType,o.RentType,o.LeaseCompID,o.CompEventID,o.CompSubmarketDisplay,
    b.PropertyName,b.StreetAddress,b.OwnerName,b.LandlordOwner,b.OwnerLandlord,b.DeveloperName,b.LeasingCompanyName,b.PrimaryAgentName
  ].filter(Boolean).join(' ').toLowerCase();
  return text.includes(String(q).toLowerCase().trim());
}
function compSpecificMatch(o){
  const cf=compFilterState||{};
  if(cf.q && !compSearchMatch(o,cf.q))return false;
  if(cf.submarket && (o.CompSubmarketDisplay||o.Submarket)!==cf.submarket)return false;
  if(cf.leaseType && !compLeaseTypeMatch(o,cf.leaseType))return false;
  if(!compSizeRangeMatch(o,cf.size))return false;
  return true;
}

function isValidSubmarketFilterValue(v){
  const s=String(v||'').trim();
  if(!s)return false;
  if(s.length>38)return false;
  if(/\b20\d{2}\b/.test(s))return false;
  if(/GEODIS|ShipBob|Pattern|Power Control|Turn5|Veho|Specialties|United States of America/i.test(s))return false;
  if(/^\d|^\$/.test(s))return false;
  return true;
}

function compFilterBarHtml(){
  const subs=[...new Set(COMPS_SAFE.map(c=>c.CompSubmarketDisplay||c.Submarket).filter(isValidSubmarketFilterValue).map(String))].sort();
  const subOpts='<option value="">All submarkets</option>'+subs.map(s=>'<option value="'+esc(s)+'" '+(compFilterState.submarket===s?'selected':'')+'>'+esc(s)+'</option>').join('');
  const sizeOpts=[
    ['','All sizes'],
    ['lt50','Under 50k SF'],
    ['50-100','50k-100k SF'],
    ['100-150','100k-150k SF'],
    ['150-250','150k-250k SF'],
    ['250-400','250k-400k SF'],
    ['400-500','400k-500k SF'],
    ['500-750','500k-750k SF'],
    ['750-1000','750k-1M SF'],
    ['1000plus','1M+ SF']
  ].map(([v,l])=>'<option value="'+v+'" '+(compFilterState.size===v?'selected':'')+'>'+l+'</option>').join('');
  const leaseTypeOpts=[
    ['','All lease types'],
    ['new','New leases'],
    ['renewal','Renewals'],
    ['sublease','Subleases']
  ].map(([v,l])=>'<option value="'+v+'" '+(compFilterState.leaseType===v?'selected':'')+'>'+l+'</option>').join('');
  return '<div class="comp-filter-bar expanded"><div class="wide"><label>Comp search</label><input id="compSearch" value="'+esc(compFilterState.q||'')+'" placeholder="Search tenant, address, building, landlord..."></div><div><label>Submarket</label><select id="compSubmarket">'+subOpts+'</select></div><div><label>Lease type</label><select id="compLeaseType">'+leaseTypeOpts+'</select></div><div><label>Size range</label><select id="compSize">'+sizeOpts+'</select></div><button id="compFilterReset" type="button">Reset comp filters</button></div>';
}
let compSearchRenderTimer=null;
function rerenderCompSearchPreserveFocus(){
  const cursor=(document.activeElement&&document.activeElement.id==='compSearch')?document.activeElement.selectionStart:null;
  render();
  const nq=$('compSearch');
  if(nq){
    nq.focus();
    const pos=cursor===null?String(nq.value||'').length:Math.min(cursor,String(nq.value||'').length);
    try{nq.setSelectionRange(pos,pos);}catch(e){}
  }
}
function bindCompFilters(){
  const q=$('compSearch'), sub=$('compSubmarket'), lt=$('compLeaseType'), sz=$('compSize'), rst=$('compFilterReset');
  if(q){
    q.oninput=()=>{
      compFilterState.q=q.value;
      clearTimeout(compSearchRenderTimer);
      compSearchRenderTimer=setTimeout(rerenderCompSearchPreserveFocus,350);
    };
    q.onkeydown=e=>{if(e.key==='Enter'){e.preventDefault(); clearTimeout(compSearchRenderTimer); rerenderCompSearchPreserveFocus();}};
  }
  if(sub)sub.onchange=()=>{compFilterState.submarket=sub.value; render();};
  if(lt)lt.onchange=()=>{compFilterState.leaseType=lt.value; render();};
  if(sz)sz.onchange=()=>{compFilterState.size=sz.value; render();};
  if(rst)rst.onclick=()=>{compFilterState={q:'',submarket:'',leaseType:'',size:''}; render();};
}

function filters(){return {q:$('search').value.trim().toLowerCase(),focus:$('focus').value,region:$('region').value,submarket:$('submarket').value,expiration:$('expiration').value,priority:$('priority').value,minsf:Number($('minsf').value)||0};}
function textMatch(o,q){if(!q)return true; return [o.Tenant,o.Company,o.PropertyName,o.StreetAddress,o.Address,o.City,o.State,o.OwnerName,o.LandlordOwner,o.Submarket,o.Region].filter(Boolean).join(' ').toLowerCase().includes(q)}
function common(o,f){return textMatch(o,f.q)&&(!f.region||o.Region===f.region)&&(!f.submarket||o.Submarket===f.submarket)}
function buildingRows(){const f=filters();return BUILDINGS_SAFE.filter(o=>common(o,f)&&num(o,['RBA','RentableBuildingArea'])>=f.minsf)}
function eventRows(){const f=filters();return EVENTS_SAFE.filter(o=>common(o,f)&&expirationMatch(o,f.expiration)&&(!f.priority||o.BDPriority===f.priority)&&num(o,['LeasedSF','SF'])>=f.minsf)}
function compSortDate(o){return String(o.ExecutionDate||o.CommencementDate||'').trim();}
function compRows(){
  const f=filters();
  return COMPS_SAFE
    .filter(o=>common(o,f)&&compSpecificMatch(o)&&expirationMatch(o,f.expiration)&&num(o,['LeaseSF','AggregateLeasedSFOrCompTotal','LeasedSF'])>=f.minsf)
    .sort((a,b)=>{
      const ae=(compRentVal(a)!==null || compNerVal(a)!==null)?1:0;
      const be=(compRentVal(b)!==null || compNerVal(b)!==null)?1:0;
      if(ae!==be)return be-ae;
      const ad=compSortDate(a), bd=compSortDate(b);
      if(ad&&bd&&ad!==bd)return bd.localeCompare(ad);
      if(ad&&!bd)return -1;
      if(!ad&&bd)return 1;
      return String(a.Tenant||a.StreetAddress||'').localeCompare(String(b.Tenant||b.StreetAddress||''));
    });
}
function rentRows(){const f=filters();return RENT_REGIONS.filter(o=>(!f.q||JSON.stringify(o).toLowerCase().includes(f.q))&&(!f.region||o.region===f.region||o.label===f.region))}


function mobileSortOptions(){
  const c=cols();
  const sel=$('mobileSort'); if(!sel)return;
  const currentVal=sel.value;
  sel.innerHTML='<option value="">Default</option>'+c.map(k=>'<option value="'+esc(k)+'">'+esc(label(k))+'</option>').join('');
  if(c.includes(currentVal))sel.value=currentVal;
}
function applyMobileSort(){
  const sel=$('mobileSort'); if(!sel)return;
  const key=sel.value;
  if(!key){sortState={tab:'',key:'',dir:'asc'}; renderRecords(); return;}
  const dir=($('mobileSortDir')&&$('mobileSortDir').dataset.dir)||'desc';
  sortState={tab:activeTab,key:key,dir:dir};
  renderRecords();
}
function syncMobileSortControls(){
  const sel=$('mobileSort'), btn=$('mobileSortDir'); if(!sel||!btn)return;
  if(sortState.tab===activeTab&&sortState.key){sel.value=sortState.key; btn.dataset.dir=sortState.dir; btn.textContent=sortState.dir==='asc'?'Asc':'Desc';}
}

function sortType(k){
  if(/date|expiration|commence|execut/i.test(k))return 'date';
  if(/sf|rba|rent|psf|pct|percent|term|months|year|vacancy|inventory|available|vacant|ner|ti/i.test(k))return 'num';
  return 'text';
}
function sortValue(row,k){
  const v=derivedValue(row,k);
  if(sortType(k)==='num'){
    const n=toNum(v);
    return n===null ? -Infinity : n;
  }
  if(sortType(k)==='date'){
    if(!v)return 0;
    const t=Date.parse(String(v));
    return isNaN(t)?0:t;
  }
  return String(v||'').toLowerCase();
}
function sortRows(rows){
  if(!sortState.key||sortState.tab!==activeTab)return rows;
  const key=sortState.key, dir=sortState.dir==='desc'?-1:1;
  return [...rows].sort((a,b)=>{
    const av=sortValue(a,key), bv=sortValue(b,key);
    if(av<bv)return -1*dir;
    if(av>bv)return 1*dir;
    return 0;
  });
}
function toggleSort(key){
  if(sortState.tab===activeTab&&sortState.key===key){
    sortState.dir=sortState.dir==='asc'?'desc':'asc';
  }else{
    sortState={tab:activeTab,key:key,dir:(sortType(key)==='text'?'asc':'desc')};
  }
  renderRecords();
}

function rows(){if(activeTab==='events')return eventRows(); if(activeTab==='comps')return compRows(); if(activeTab==='rents')return rentRows(); return buildingRows();}
function render(){current=rows(); updateKpis(); updateSection(); renderDataQa(); renderRecords(); renderMap(); closeFilters();}

function renderDataQa(){ const el=$('dataQaBanner'); if(el) el.innerHTML=''; }

function updateKpis(){const b=buildingRows(), e=eventRows(); const rba=b.reduce((s,o)=>s+num(o,['RBA','RentableBuildingArea']),0), vac=b.reduce((s,o)=>s+num(o,['DirectVacantSF','VacantSF']),0), avail=b.reduce((s,o)=>s+num(o,['AvailableSF','TotalAvailableSF']),0); const comps=COMPS_SAFE||[]; const nerCt=comps.filter(c=>compNerVal(c)!==null).length; $('k-events').textContent=fmt(e.length); $('k-events-sub').textContent=fmt(e.filter(x=>String(x.BDPriority||'').toLowerCase().includes('high')).length)+' high priority'; $('k-inventory-msf').textContent=msf(rba); $('k-buildings-sub').textContent=fmt(b.length)+' buildings'; $('k-comps').textContent=fmt(comps.length); $('k-comps-sub').textContent=fmt(nerCt)+' with NER'; const score=leverageScore(rba,avail,vac); const fill=$('k-leverage-fill'), gauge=$('k-leverage-gauge'); $('k-leverage-score').textContent=score; $('k-leverage-label').textContent=leverageLabel(score); $('k-leverage-sub').textContent='1 = tenant leverage · 100 = landlord leverage'; if(fill){fill.style.transform='rotate('+(-90+(score*1.8))+'deg)'; fill.style.background=leverageColor(score);} if(gauge){gauge.style.setProperty('--gauge-color',leverageColor(score));}}
function updateSection(){const names={buildings:'Building inventory',comps:'Comps',events:'Lease events',rents:'Market AI insights'}; const notes={buildings:'Property inventory and building profile view.',events:'Upcoming lease expirations with current rent, market rent and renewal / relocation context.',comps:'Matched lease transactions with actual rents, term, concessions, TI, landlord and NER. NER represents average lease economics, not today\'s escalated rent.',rents:'Market analysis using Savills research benchmarks with building, comp, and lease-event context.'}; $('sectionTitle').textContent=names[activeTab]; mobileSortOptions(); syncMobileSortControls(); let extra=''; if(activeTab==='comps'){const rentCt=current.filter(x=>compRentVal(x)!==null||compNerVal(x)!==null).length; extra=' · '+fmt(rentCt)+' with rent economics';} $('sectionSub').textContent=activeTab==='rents'?notes.rents:fmt(current.length)+' visible '+(activeTab==='buildings'?'building':activeTab==='events'?'lease event':activeTab==='comps'?'comp':'market rent')+' records'+extra+' · '+notes[activeTab];}
function renderRecords(){if($('tableWrap'))$('tableWrap').innerHTML=''; if($('cards'))$('cards').innerHTML=''; if(activeTab==='rents'){renderMarketAIInsights();return;}renderTable(); renderCards();}



const HISTORICAL_ASKING_RENTS = {
  'NNJ': {
    label: 'Northern New Jersey',
    values: {
      2021: 8.80,
      2022: 13.20,
      2023: 16.50,
      2024: 17.20,
      2025: 16.75,
      2026: 16.12
    }
  },
  'PA I-81/78': {
    label: 'PA I-81 / I-78 Corridor',
    values: {
      2021: 4.60,
      2022: 6.10,
      2023: 8.00,
      2024: 8.30,
      2025: 8.30,
      2026: 9.01
    }
  },
  'PHL/SNJ': {
    label: 'Philadelphia / Southern New Jersey',
    values: {
      2021: 5.60,
      2022: 8.90,
      2023: 11.30,
      2024: 12.00,
      2025: 12.09,
      2026: 12.06
    }
  }
};

function marketInsightData(){return window.MARKET_AI_INSIGHTS||{}}


function compDateForRecent(c){
  return parseDateLoose(c.ExecutionDate||c.CommencementDate||c.TransactionDate||c.ExpirationDate);
}
function recentCompCutoff(months){
  const d=new Date();
  d.setHours(0,0,0,0);
  d.setMonth(d.getMonth()-(months||12));
  return d;
}
function isRecentComp(c,months=12){
  const d=compDateForRecent(c);
  if(!d)return false;
  return d>=recentCompCutoff(months);
}
function recentCompsForRegion(regionKey){
  return COMPS_SAFE.filter(c=>compRegionKey(c)===regionKey && isRecentComp(c,12));
}
function compRentForAnalysis(c){
  return toNum(c.StartingRentPSF)||toNum(c.CurrentRentPSF)||toNum(c.NetEffectiveRentPSF)||toNum(c.CalculatedNERPSF)||toNum(c.SourceNetEffectiveRentPSF)||null;
}
function compSizeForAnalysis(c){
  return toNum(c.LeaseSF)||toNum(c.AggregateLeasedSFOrCompTotal)||toNum(c.LeasedSF)||0;
}
function sizeBandForComp(c){
  const sf=compSizeForAnalysis(c);
  if(sf>=500000)return '500k+ SF';
  if(sf>=250000)return '250k-500k SF';
  if(sf>=100000)return '100k-250k SF';
  return '<100k SF';
}

function avgCompRentForRegion(regionKey){
  const vals=recentCompsForRegion(regionKey).map(c=>compRentForAnalysis(c)).filter(v=>v!==null&&v>0);
  if(!vals.length)return null;
  return vals.reduce((a,b)=>a+b,0)/vals.length;
}
function compRentCountForRegion(regionKey){
  return recentCompsForRegion(regionKey).filter(c=>compRentForAnalysis(c)!==null).length;
}
function marketSummaryCard(regionKey,d){
  const compAvg=avgCompRentForRegion(regionKey);
  const compCt=compRentCountForRegion(regionKey);
  const barWidth=Math.max(8,Math.min(100,(d.savills_rent||0)/18*100));
  return '<div class="ai-market-summary-card"><h3>'+esc(d.title)+'</h3><div class="summary-metrics"><div class="summary-metric"><span>Average Asking Rents (Savills Research)</span><strong>'+moneyPsf(d.savills_rent)+'</strong></div><div class="summary-metric"><span>Vacancy</span><strong>'+pct(d.savills_vac)+'</strong></div><div class="summary-metric"><span>Avg. recent comp rent</span><strong>'+moneyPsf(compAvg)+'</strong></div></div><div class="summary-bar"><i style="width:'+barWidth+'%"></i></div><div class="summary-note">Q1 2026 Savills research benchmark with average rent from '+fmt(compCt)+' comps executed in the last 12 months.</div></div>';
}
function renderMarketTopSummary(vals){
  const keys=['NNJ','PA I-81/78','PHL/SNJ'];
  let html='<div class="ai-panel"><h3>Market AI summary</h3><p>Savills Q1 2026 asking rent and vacancy by core market, compared with recent matched comp rent from the last 12 months.</p></div>';
  html+='<div class="ai-market-summary-grid">'+keys.map(k=>marketInsightData()[k]?marketSummaryCard(k,marketInsightData()[k]):'').join('')+'</div>';
  return html;
}


function compYearForTrend(c){
  const d=compDateForRecent(c);
  return d ? d.getFullYear() : null;
}
function annualCompAvgForRegion(regionKey, year){
  const vals=COMPS_SAFE
    .filter(c=>compRegionKey(c)===regionKey && compYearForTrend(c)===year)
    .map(c=>compRentForAnalysis(c))
    .filter(v=>v!==null&&v>0);
  if(!vals.length)return {avg:null,count:0};
  return {avg:vals.reduce((a,b)=>a+b,0)/vals.length,count:vals.length};
}
function historicalTrendRows(regionKey){
  const years=[2021,2022,2023,2024,2025,2026];
  const asking=(HISTORICAL_ASKING_RENTS[regionKey]||{}).values||{};
  return years.map(y=>{
    const comp=annualCompAvgForRegion(regionKey,y);
    return {year:y,asking:asking[y]||null,comp:comp.avg,count:comp.count};
  });
}
function historicalTrendCard(regionKey){
  const meta=HISTORICAL_ASKING_RENTS[regionKey]||{};
  const rows=historicalTrendRows(regionKey);
  const vals=[];
  rows.forEach(r=>{if(r.asking)vals.push(r.asking); if(r.comp)vals.push(r.comp);});
  const max=Math.max(...vals,1);
  let html='<div class="ai-trend-card"><h4>'+esc(meta.label||regionKey)+'</h4><div class="ai-trend-legend"><span><i class="ask"></i>Average Asking Rents (Savills Research)</span><span><i class="comp"></i>Avg. comp rent</span></div>';
  html+='<div class="ai-trend-rows">'+rows.map(r=>{
    const askW=r.asking?Math.max(7,(r.asking/max)*100):0;
    const compW=r.comp?Math.max(7,(r.comp/max)*100):0;
    return '<div class="ai-trend-row"><div class="ai-trend-year">'+r.year+'</div><div class="ai-trend-bars"><div class="ai-trend-bar ask"><span style="width:'+askW+'%"></span><b>'+moneyPsf(r.asking)+'</b></div><div class="ai-trend-bar comp"><span style="width:'+compW+'%"></span><b>'+moneyPsf(r.comp)+'</b></div></div><div class="ai-trend-count">'+(r.count?fmt(r.count)+' comps':'—')+'</div></div>';
  }).join('')+'</div></div>';
  return html;
}
function renderHistoricalRentTrend(){
  const keys=['NNJ','PA I-81/78','PHL/SNJ'];
  return '<div class="ai-panel ai-historical-section"><h3>Historical asking rent vs. comp rent</h3><p>Five-year view using Savills Q1 asking-rent trend points and annual average matched comp rents from the database. This is directional market context; the comp evidence table remains the detailed transaction file.</p><div class="ai-trend-grid">'+keys.map(k=>historicalTrendCard(k)).join('')+'</div></div>';
}

function renderMarketAIInsights(){
  const data=marketInsightData();
  const vals=['NNJ','PA I-81/78','PHL/SNJ'].map(k=>data[k]).filter(Boolean);
  let html='<div class="ai-insights">';
  html+=renderMarketTopSummary(vals);
  html+=renderHistoricalRentTrend();
  html+=renderSizeBandAnalysis();
  html+='<div class="ai-report-grid">'+vals.map(d=>marketReportCard(d)).join('')+'</div>';
  html+='<div class="ai-panel"><h3>Savills rent benchmark comparison</h3><p>Q1 2026 Average Asking Rents (Savills Research) benchmark by core market.</p><div class="ai-chart">'+vals.map(d=>{const width=Math.max(8,Math.min(100,(d.savills_rent||0)/18*100)); return '<div class="ai-col"><div class="ai-col-label"><strong>'+esc(d.title)+'</strong> · '+moneyPsf(d.savills_rent)+' · '+pct(d.savills_vac)+' vacancy</div><div class="ai-bar"><i style="width:'+width+'%"></i></div></div>';}).join('')+'</div></div>';
  html+=renderSubmarketEconomics(); html+=renderCompTrendCharts(); html+='</div>';
  $('tableWrap').innerHTML=html;
  $('cards').innerHTML=html;
  if($('cards')){$('cards').style.display='grid';}
  document.querySelectorAll('[data-report]').forEach(btn=>btn.onclick=()=>openMarketReport(btn.dataset.report));
}
function marketReportCard(d){
  const sub=(d.submarkets||[]).slice(0,4);
  let html='<div class="ai-report-card"><div class="ai-report-top"><h4>'+esc(d.title)+'</h4><span class="ai-pill">'+esc(d.report_date||'Q1 2026')+'</span></div>';
  html+='<div class="ai-report-thumb"><img src="'+esc((d.report_thumbs&&d.report_thumbs[0])||'')+'" alt="'+esc(d.title)+' report thumbnail"></div>';
  html+='<div class="ai-metrics"><div class="ai-metric"><span>Savills rent</span><strong>'+moneyPsf(d.savills_rent)+'</strong></div><div class="ai-metric"><span>Vacancy</span><strong>'+pct(d.savills_vac)+'</strong></div><div class="ai-metric"><span>Inventory</span><strong>'+fmt(d.inventory_msf)+' MSF</strong></div><div class="ai-metric"><span>Events / comps</span><strong>'+fmt((d.database&&d.database.lease_events)||0)+' / '+fmt((d.database&&d.database.matched_comps)||0)+'</strong></div></div>';
  html+='<p>'+esc(d.narrative||'')+'</p>';
  const orderedSub=[...sub].sort((a,b)=>(String(a.name).toLowerCase()==='overall'?-1:String(b.name).toLowerCase()==='overall'?1:0)); html+='<div class="ai-bars">'+orderedSub.map((s,idx)=>{const max=Math.max(...orderedSub.map(x=>x.rent||0),1); const pctv=Math.max(8,(s.rent||0)/max*100); const overall=String(s.name).toLowerCase()==='overall'; return '<div class="ai-bar-row '+(overall?'overall':'')+'"><span>'+esc(s.name)+'</span><div class="ai-bar"><i class="subbar-'+idx+'" style="width:'+pctv+'%"></i></div><strong>'+moneyPsf(s.rent)+'</strong></div>';}).join('')+'</div>';
  html+='<button class="ai-button" data-report="'+esc(d.title)+'">Enlarge Savills report</button></div>';
  return html;
}
function openMarketReport(title){
  const d=Object.values(marketInsightData()).find(x=>x.title===title); if(!d)return;
  let html='<div class="ai-modal open" id="aiModal"><div class="ai-modal-card"><div class="ai-modal-head"><h3>'+esc(d.title)+' · Savills Market in Minutes</h3><button class="ai-close" id="aiClose">Close</button></div><div class="ai-modal-body">';
  html+='<div class="report-summary-grid"><div class="report-page"><h4>Q1 2026 market read</h4><div class="report-stat"><div><span>Asking rent</span><strong>'+moneyPsf(d.savills_rent)+'</strong></div><div><span>Vacancy</span><strong>'+pct(d.savills_vac)+'</strong></div><div><span>Inventory</span><strong>'+fmt(d.inventory_msf)+' MSF</strong></div></div><p>'+esc(d.narrative||'')+'</p><ul>'+((d.takeaways||[]).map(x=>'<li>'+esc(x)+'</li>').join(''))+'</ul></div>';
  html+='<div class="report-page"><h4>Database overlay</h4><div class="report-stat"><div><span>Buildings</span><strong>'+fmt((d.database&&d.database.buildings)||0)+'</strong></div><div><span>BD events</span><strong>'+fmt((d.database&&d.database.lease_events)||0)+'</strong></div><div><span>Matched comps</span><strong>'+fmt((d.database&&d.database.matched_comps)||0)+'</strong></div></div><p>AI interpretation: use the Savills report as the research baseline and the dashboard data as the live execution layer for lease-event targeting, comp validation and submarket-specific renewal strategy.</p></div></div>';
  html+='<div class="report-pages">'+(d.report_pages||[]).map((src,i)=>'<div class="report-page-img"><img src="'+esc(src)+'" alt="'+esc(d.title)+' report page '+(i+1)+'"></div>').join('')+'</div>';
  html+='</div></div></div>';
  document.body.insertAdjacentHTML('beforeend',html); $('aiClose').onclick=()=>{$('aiModal').remove();}; $('aiModal').onclick=e=>{if(e.target.id==='aiModal')e.currentTarget.remove();};
}


function parseDateLoose(v){
  if(!v)return null;
  const s=String(v).trim();
  if(!s)return null;
  const d=new Date(s);
  if(!isNaN(d))return d;
  const m=s.match(/^(\d{4})-(\d{2})-(\d{2})$/); if(m)return new Date(+m[1],+m[2]-1,+m[3]);
  return null;
}
function compRegionKey(c){
  const s=String(c.Region||c.Market||'').toLowerCase();
  if(s.includes('nnj')||s.includes('northern new jersey'))return 'NNJ';
  if(s.includes('81')||s.includes('78')||s.includes('corridor'))return 'PA I-81/78';
  if(s.includes('phl')||s.includes('philadelphia')||s.includes('snj')||s.includes('southern'))return 'PHL/SNJ';
  return null;
}
function quarterKeyFromDate(d){
  if(!d||isNaN(d))return null;
  const q=Math.floor(d.getMonth()/3)+1;
  return d.getFullYear()+' Q'+q;
}
function recentQuarterKeys(n){
  const keys=[]; const now=new Date(); let y=now.getFullYear(), q=Math.floor(now.getMonth()/3)+1;
  for(let i=0;i<n;i++){ keys.unshift(y+' Q'+q); q--; if(q===0){q=4;y--;} }
  return keys;
}

function termYearsForComp(c){
  const months=toNum(c.LeaseTermMonths);
  if(months&&months>0)return months/12;
  const start=parseDateLoose(c.CommencementDate||c.ExecutionDate);
  const end=parseDateLoose(c.ExpirationDate);
  if(start&&end&&end>start){
    const days=(end-start)/(1000*60*60*24);
    return Math.max(days/365.25,0);
  }
  return null;
}
function cleanCompEconomicsForCharts(c){
  const free=toNum(c.FreeRentMonthsClean);
  const ti=toNum(c.TIValuePSFClean);
  const ner=toNum(c.NetEffectiveRentPSF)||toNum(c.SourceNetEffectiveRentPSF)||toNum(c.CalculatedNERPSF)||null;
  const starting=toNum(c.StartingRentPSF)||null;
  const termYears=termYearsForComp(c);
  const freeValue=(free!==null&&starting!==null)?(free/12)*starting:null;
  const totalConcession=(freeValue!==null||ti!==null)?((freeValue||0)+(ti||0)):null;
  return {
    region: compRegionKey(c),
    submarket: cleanSubmarketName(c.Submarket||c.SubMarket||c.Sub_Market||c.SubmarketName),
    date: parseDateLoose(c.ExecutionDate||c.CommencementDate||c.Executed||c.execution_date),
    termYears: termYears,
    free: free,
    ti: ti,
    ner: ner,
    starting: starting,
    freePerYear:(free!==null&&termYears)?free/termYears:null,
    tiPerYear:(ti!==null&&termYears)?ti/termYears:null,
    concessionPerYear:(totalConcession!==null&&termYears)?totalConcession/termYears:null,
    nerSpread:(starting!==null&&ner!==null)?starting-ner:null
  };
}
function avg(arr){const vals=arr.filter(v=>typeof v==='number'&&!isNaN(v)); if(!vals.length)return null; return vals.reduce((a,b)=>a+b,0)/vals.length;}
function buildCompTrendSeries(){
  const keys=recentQuarterKeys(4);
  const regions=['NNJ','PA I-81/78','PHL/SNJ'];
  const out={free:{},ti:{},ner:{},concession:{},spread:{}};
  regions.forEach(r=>{out.free[r]=[]; out.ti[r]=[]; out.ner[r]=[]; out.concession[r]=[]; out.spread[r]=[];});
  const grouped={};
  COMPS_SAFE.forEach(c=>{
    if(!isRecentComp(c,12))return;
    const row=cleanCompEconomicsForCharts(c);
    if(!row.region||!row.date)return;
    const qk=quarterKeyFromDate(row.date); if(!qk)return;
    if(!keys.includes(qk))return;
    grouped[row.region] ||= {};
    grouped[row.region][qk] ||= {free:[],ti:[],ner:[],concession:[],spread:[]};
    if(row.freePerYear!==null)grouped[row.region][qk].free.push(row.freePerYear);
    if(row.tiPerYear!==null)grouped[row.region][qk].ti.push(row.tiPerYear);
    if(row.ner!==null)grouped[row.region][qk].ner.push(row.ner);
    if(row.concessionPerYear!==null)grouped[row.region][qk].concession.push(row.concessionPerYear);
    if(row.nerSpread!==null)grouped[row.region][qk].spread.push(row.nerSpread);
  });
  regions.forEach(r=>{
    keys.forEach(k=>{
      const g=(grouped[r]&&grouped[r][k])||{free:[],ti:[],ner:[],concession:[],spread:[]};
      out.free[r].push(avg(g.free));
      out.ti[r].push(avg(g.ti));
      out.ner[r].push(avg(g.ner));
      out.concession[r].push(avg(g.concession));
      out.spread[r].push(avg(g.spread));
    });
  });
  out.keys=keys;
  return out;
}
function cleanSubmarketName(raw){
  const s=String(raw||'').trim();
  if(!s || s==='...' || s==='Overall') return null;
  if(s.length>38) return null;
  if(/\b20\d{2}\b/.test(s) || /\bQ[1-4]\b/i.test(s)) return null;
  if(/rent schedule|specialties|power control|shipbob|pattern|geodis|turn5|veho|united states of america/i.test(s)) return null;
  return s;
}
function submarketEconomicsSeries(regionKey){
  const bySub={};
  COMPS_SAFE.forEach(c=>{
    if(!isRecentComp(c,12))return;
    const row=cleanCompEconomicsForCharts(c);
    if(row.region!==regionKey || !row.submarket) return;
    const sub=row.submarket;
    bySub[sub] ||= {name:sub,count:0,freePerYear:[],tiPerYear:[],concessionPerYear:[],nerSpread:[],ner:[]};
    bySub[sub].count += 1;
    if(row.freePerYear!==null) bySub[sub].freePerYear.push(row.freePerYear);
    if(row.tiPerYear!==null) bySub[sub].tiPerYear.push(row.tiPerYear);
    if(row.concessionPerYear!==null) bySub[sub].concessionPerYear.push(row.concessionPerYear);
    if(row.nerSpread!==null) bySub[sub].nerSpread.push(row.nerSpread);
    if(row.ner!==null) bySub[sub].ner.push(row.ner);
  });
  const valid = Object.values(bySub).filter(x=>x.count>=3).map(x=>({
    name:x.name,
    count:x.count,
    freePerYear:avg(x.freePerYear),
    tiPerYear:avg(x.tiPerYear),
    concessionPerYear:avg(x.concessionPerYear),
    nerSpread:avg(x.nerSpread),
    ner:avg(x.ner)
  })).sort((a,b)=>b.count-a.count || String(a.name).localeCompare(String(b.name)));
  return valid.slice(0,6);
}
function econMetricCard(metric,title,desc,rows){
  const cleanRows=rows.filter(x=>typeof x[metric]==='number' && !isNaN(x[metric]));
  if(!cleanRows.length){
    return '<div class="ai-econ-card"><h5>'+title+'</h5><p>'+desc+'</p><div class="ai-econ-empty">Insufficient clean comp economics in this market.</div></div>';
  }
  const max=Math.max(...cleanRows.map(x=>Math.abs(x[metric])),1);
  return '<div class="ai-econ-card"><h5>'+title+'</h5><p>'+desc+'</p>'+cleanRows.map(r=>{
    const width=Math.max(10, Math.abs(r[metric])/max*100);
    return '<div class="ai-econ-row"><div class="ai-econ-name">'+esc(r.name)+'</div><div class="ai-econ-bar"><span style="width:'+width+'%"></span></div><div class="ai-econ-value">'+metricFmt(metric, r[metric])+'</div></div>';
  }).join('')+'<div class="ai-econ-note">Shown only where clean lease-term and economics data are available.</div></div>';
}
function submarketEconomicsCard(regionKey,d){
  const rows=submarketEconomicsSeries(regionKey);
  return '<div class="ai-econ-market"><h4>'+esc(d.title)+'</h4><p>Normalized concession analysis by submarket. Raw free rent and TI are annualized over lease term so concessions can be compared apples-to-apples.</p><div class="ai-econ-meta"><span class="ai-econ-chip">'+fmt(rows.length)+' visible submarkets</span><span class="ai-econ-chip">'+fmt((d.database&&d.database.matched_comps)||0)+' matched comps</span></div><div class="ai-econ-grid">'+
    econMetricCard('freePerYear','Free rent / lease year','Average free-rent months per year of lease term.',rows)+
    econMetricCard('tiPerYear','TI / PSF / year','Average tenant improvement allowance annualized over lease term.',rows)+
    econMetricCard('concessionPerYear','Total concession / PSF / year','Free-rent value plus TI, annualized over lease term.',rows)+
    econMetricCard('ner','Average NER / PSF','Average net effective rent by submarket.',rows)+
  '</div></div>';
}
function renderSubmarketEconomics(){
  const data=marketInsightData();
  const keys=['NNJ','PA I-81/78','PHL/SNJ'];
  return '<div class="ai-panel ai-econ-section"><h3>Annualized concession intensity</h3><p>Free rent and TI are normalized by lease term to compare landlord concession pressure across submarkets. This analysis uses matched comps executed in the last 12 months.</p><div class="ai-concession-method"><strong>Method:</strong> Free rent / lease year = free rent months ÷ lease term years. TI / PSF / year = TI PSF ÷ lease term years. Total concession / PSF / year = ((free rent months ÷ 12) × starting rent + TI PSF) ÷ lease term years. Average NER / PSF reflects net effective rent economics from the matched comp records.</div><div class="ai-econ-market-grid">'+keys.map(k=>data[k]?submarketEconomicsCard(k,data[k]):'').join('')+'</div></div>';
}

function latestNonNull(arr){
  for(let i=arr.length-1;i>=0;i--){
    if(typeof arr[i]==='number' && !isNaN(arr[i])) return {value:arr[i], index:i};
  }
  return {value:null,index:-1};
}
function prevNonNull(arr, beforeIdx){
  for(let i=(beforeIdx===undefined?arr.length-2:beforeIdx-1);i>=0;i--){
    if(typeof arr[i]==='number' && !isNaN(arr[i])) return arr[i];
  }
  return null;
}
function metricFmt(metric, v){
  if(v===null||v===undefined||isNaN(v))return '—';
  if(metric==='free'||metric==='freePerYear')return v.toFixed(2)+' mo./yr';
  if(metric==='ti'||metric==='tiPerYear'||metric==='concession'||metric==='concessionPerYear')return '$'+v.toFixed(2)+' PSF/yr';
  return '$'+v.toFixed(2)+(metric==='ner'?' PSF':'');
}
function deltaFmt(metric, latest, prev){
  if(latest===null||prev===null||latest===undefined||prev===undefined||isNaN(latest)||isNaN(prev)) return {cls:'flat',text:'Insufficient recent history'};
  const diff=latest-prev;
  const abs=Math.abs(diff);
  let text='';
  if(metric==='free'||metric==='freePerYear') text=(diff>=0?'+':'-')+abs.toFixed(2)+' mo./yr vs prior quarter';
  else text=(diff>=0?'+':'-')+'$'+abs.toFixed(2)+' vs prior quarter';
  return {cls: diff>0.001?'up': diff<-0.001?'down':'flat', text};
}
function barChartCard(metric, title, desc, seriesMap, keys){
  const regions=[
    {key:'NNJ', name:'Northern New Jersey', cls:'nnj'},
    {key:'PA I-81/78', name:'PA I-81 / I-78 Corridor', cls:'pac'},
    {key:'PHL/SNJ', name:'Philadelphia / Southern New Jersey', cls:'phl'}
  ];
  const latestVals=regions.map(r=>latestNonNull(seriesMap[r.key]||[]).value).filter(v=>typeof v==='number'&&!isNaN(v));
  const max=Math.max(...latestVals.map(v=>Math.abs(v)), 0.0001);
  const latestKey=keys[keys.length-1]||'Recent quarter';
  let html='<div class="ai-chart-card">';
  html+='<h4>'+esc(title)+'</h4>';
  html+='<p>'+esc(desc)+'</p>';
  html+='<div class="ai-period-badge">Latest quarter · '+esc(latestKey)+'</div>';
  html+='<div class="ai-region-stack">';
  regions.forEach(r=>{
    const arr=seriesMap[r.key]||[];
    const latest=latestNonNull(arr);
    const prev=prevNonNull(arr, latest.index);
    const delta=deltaFmt(metric, latest.value, prev);
    const width = latest.value===null?0:Math.max(8,(Math.abs(latest.value)/max)*100);
    html+='<div class="ai-region-block">';
    html+='<div class="ai-region-row"><div class="label">'+esc(r.name)+'</div><div class="ai-bar"><span class="'+r.cls+'" style="width:'+width+'%"></span></div><div class="value">'+esc(metricFmt(metric, latest.value))+'</div></div>';
    html+='<div class="ai-delta '+delta.cls+'"><strong>'+esc(delta.text)+'</strong></div>';
    html+='</div>';
  });
  html+='</div>';
  html+='<div class="ai-chart-foot"><span>Metric: '+esc(metric==='freePerYear'?'latest avg free rent / year':metric==='tiPerYear'?'latest avg TI / PSF / year':metric==='concessionPerYear'?'latest avg total concession / PSF / year':metric==='ner'?'latest avg NER / PSF':'latest average')+'</span><span>Matched comps</span></div>';
  html+='</div>';
  return html;
}


function sizeBandRowsForRegion(regionKey){
  const bands=['100k-250k SF','250k-500k SF','500k+ SF'];
  const by={};
  bands.forEach(b=>by[b]={band:b,count:0,rents:[],ner:[],sf:[]});
  recentCompsForRegion(regionKey).forEach(c=>{
    const band=sizeBandForComp(c);
    if(!by[band])return;
    const rent=compRentForAnalysis(c);
    const ner=toNum(c.NetEffectiveRentPSF)||toNum(c.SourceNetEffectiveRentPSF)||toNum(c.CalculatedNERPSF)||null;
    const sf=compSizeForAnalysis(c);
    by[band].count+=1;
    if(rent!==null&&rent>0)by[band].rents.push(rent);
    if(ner!==null&&ner>0)by[band].ner.push(ner);
    if(sf>0)by[band].sf.push(sf);
  });
  return bands.map(b=>({
    band:b,
    count:by[b].count,
    avgRent:avg(by[b].rents),
    avgNer:avg(by[b].ner),
    avgSf:avg(by[b].sf)
  }));
}
function sizeBandCard(regionKey,d){
  const rows=sizeBandRowsForRegion(regionKey);
  const vals=rows.map(r=>r.avgRent).filter(v=>typeof v==='number'&&!isNaN(v));
  const max=Math.max(...vals,1);
  let html='<div class="ai-size-card"><h4>'+esc(d.title)+'</h4><p>Recent comp rent by deal size. This helps identify whether larger footprints are trading at a lower PSF than smaller deals.</p>';
  html+='<div class="ai-size-rows">'+rows.map((r,idx)=>{
    const width=r.avgRent?Math.max(8,(r.avgRent/max)*100):0;
    return '<div class="ai-size-row"><div class="ai-size-top"><span>'+esc(r.band)+'</span><strong>'+moneyPsf(r.avgRent)+'</strong></div><div class="ai-size-bar"><i class="sizebar-'+idx+'" style="width:'+width+'%"></i></div><div class="ai-size-sub">'+fmt(r.count)+' recent comps'+(r.avgNer?' · NER '+moneyPsf(r.avgNer):'')+'</div></div>';
  }).join('')+'</div></div>';
  return html;
}
function renderSizeBandAnalysis(){
  const data=marketInsightData();
  const keys=['NNJ','PA I-81/78','PHL/SNJ'];
  return '<div class="ai-panel ai-size-section"><h3>Recent comp rent by deal size</h3><p>Recent matched comps are segmented by lease size to show whether larger requirements are trading at a different PSF than smaller deals. This section uses comps executed in the last 12 months only.</p><div class="ai-size-grid">'+keys.map(k=>data[k]?sizeBandCard(k,data[k]):'').join('')+'</div></div>';
}

function renderCompTrendCharts(){
  const s=buildCompTrendSeries();
  let html='<div class="ai-panel"><h3>Market-wide annualized concessions</h3><p>Recent-quarter comparison across the three core markets using normalized concession metrics from last-12-month comps.</p><div class="ai-chart-grid">';
  html+=barChartCard('freePerYear','Free rent / lease year','Latest average free-rent months per year of lease term.',s.free,s.keys);
  html+=barChartCard('tiPerYear','TI / PSF / year','Latest average TI allowance annualized over lease term.',s.ti,s.keys);
  html+=barChartCard('concessionPerYear','Total concession / PSF / year','Free-rent value plus TI, annualized over lease term.',s.concession,s.keys);
  html+=barChartCard('ner','Average NER / PSF','Latest average net effective rent across the three core markets.',s.ner,s.keys);
  html+='</div></div>';
  return html;
}


function cols(){return activeTab==='events'?['Tenant','StreetAddress','City','State','LeasedSF','LeaseExpirationDate','CurrentRentPSF','MarketBenchmarkPSF','RentDeltaPct','LandlordOwner']:activeTab==='comps'?['Tenant','StreetAddress','City','State','CompSubmarketDisplay','TransactionType','LeaseSF','CommencementDate','ExpirationDate','StartingRentPSF','RentEscalationClean','FreeRentMonths','TIValuePSF','NetEffectiveRentPSF','OwnerLandlord']:activeTab==='rents'?['region','label','overall_asking_rent','overall_vacancy_pct','inventory_msf','report_date']:['StreetAddress','City','State','RBA','DirectVacantSF','AvailableSF','Submarket'];}
function colClass(k,v,r){let c=''; if(/SF|Rent|PSF|Pct|Year|Months/i.test(k))c+=' num'; if(/Rent|PSF|Pct|Position/i.test(k))c+=' rent'; if(['Tenant','StreetAddress','LandlordOwner','OwnerName','OwnerDisplay','OwnerLandlordDisplay','OwnerTableDisplay','OwnerTableDisplay','LandlordOwner','OwnerLandlord','PropertyName'].includes(k))c+=' tight'; const vc=valueClass(k,v,r); return (c+' '+vc).trim();}
function renderTable(){const c=cols();const sorted=sortRows(current);let html=(activeTab==='comps'?compFilterBarHtml():'')+'<table class="table"><thead><tr>'+c.map(x=>'<th class="sortable '+(sortState.tab===activeTab&&sortState.key===x?(sortState.dir==='asc'?'sorted-asc':'sorted-desc'):'')+'" data-sort="'+x+'">'+label(x)+'</th>').join('')+'</tr></thead><tbody>';sorted.slice(0,350).forEach((r,i)=>{html+='<tr data-i="'+i+'">'+c.map(k=>{const v=(['OwnerTableDisplay','OwnerLandlordDisplay','OwnerDisplay','OwnerName','LandlordOwner','OwnerLandlord','Landlord'].includes(k)?(tableOwnerValue(r)||ownerFromAnyField(r)):derivedValue(r,k)); return '<td class="'+colClass(k,v,r)+'">'+cell(k,v,r)+'</td>'}).join('')+'</tr>'});html+='</tbody></table>'; $('tableWrap').innerHTML=html; if(activeTab==='comps')bindCompFilters(); $('tableWrap').querySelectorAll('[data-sort]').forEach(el=>el.onclick=()=>toggleSort(el.dataset.sort)); $('tableWrap').querySelectorAll('[data-i]').forEach(el=>el.onclick=()=>openDetail(sorted[Number(el.dataset.i)]));}

function renderCards(){const sorted=sortRows(current);let html=(activeTab==='comps'?compFilterBarHtml():''); sorted.slice(0,80).forEach((r,i)=>{html+=card(r,i)}); if(sorted.length>80) html+='<div class="record">Showing first 80 records. Use filters/search to narrow the list.</div>'; $('cards').innerHTML=html||'<div class="record">No matching records.</div>'; if(activeTab==='comps')bindCompFilters(); $('cards').querySelectorAll('[data-i]').forEach(el=>el.onclick=()=>openDetail(sorted[Number(el.dataset.i)])); $('cards').querySelectorAll('[data-email]').forEach(el=>el.onclick=(ev)=>{ev.stopPropagation();copyPrompt(EVENTS_SAFE[Number(el.dataset.email)]);});}
function esc(s){return String(s??'').replace(/[&<>"']/g,m=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]))}
function label(k){const custom={CurrentRentPSF:'Current rent',MarketBenchmarkPSF:'Market rent',RentDeltaPSF:'$ delta',RentDeltaPct:'% above/below',LeaseExpirationDate:'Expiration',LeasedSF:'Leased SF',LeaseSF:'Square feet',StartingRentPSF:'Starting rent',CalculatedCurrentRentPSF:'Escalated rent today',NetEffectiveRentPSF:'NER',SourceNetEffectiveRentPSF:'Source NER',CalculatedNERPSF:'Calc NER',TIValuePSF:'TI / PSF',TIValuePSFClean:'TI / PSF',FreeRentMonths:'Free rent',FreeRentMonthsClean:'Free rent',LeaseTermMonths:'Term',ExecutionDate:'Executed',CommencementDate:'Commenced',ExpirationDate:'Expires',OwnerLandlord:'Landlord',OwnerName:'Owner / landlord',OwnerDisplay:'Owner / landlord',OwnerTableDisplay:'Owner / landlord',OwnerLandlordDisplay:'Owner / landlord',OwnerTableDisplay:'Owner / landlord',CompSubmarketDisplay:'Submarket',RentTypeClean:'Rent type',RentEscalationClean:'Annual escalation',TransactionType:'Lease type'}; if(custom[k])return custom[k]; return String(k).replace(/BD/g,'B D').replace(/PSF/g,' P S F').replace(/Pct/g,' Pct').replace(/([A-Z])/g,' $1').replace(/^./,s=>s.toUpperCase()).replace(' S F',' SF').replace(' R B A','RBA').replace(' P S F',' PSF').replace(' Pct',' pct')}
function isNil(v){return v===undefined||v===null||v===''||Number.isNaN(v)}
function toNum(v){if(isNil(v))return null; if(typeof v==='number')return Number.isFinite(v)?v:null; const n=Number(String(v).replace(/[$,%\s,]/g,'')); return Number.isFinite(n)?n:null}
function fmtYear(v){const n=toNum(v); return n?String(Math.round(n)):(v||'—')}
function moneyPsf(v){const n=toNum(v); return n===null?'—':'$'+n.toFixed(2)+' PSF'}
function moneyPlain(v){const n=toNum(v); return n===null?'—':'$'+n.toFixed(2)}
function deltaPsf(v){const n=toNum(v); if(n===null)return '—'; return (n<0?'-':'')+'$'+Math.abs(n).toFixed(2)+' PSF'}
function pctVal(v){let n=toNum(v); if(n===null)return '—'; if(Math.abs(n)<=1)n=n*100; return n.toFixed(Math.abs(n)<10?1:0)+'%'}
function signedPct(v){let n=toNum(v); if(n===null)return '—'; if(Math.abs(n)<=1)n=n*100; return (n>0?'+':'')+n.toFixed(1)+'%'}
function monthsVal(v){const n=toNum(v); return n===null?(v||'—'):String(Math.round(n))}
function fmtValue(k,v,o){
  if(isNil(v))return '—'; const key=String(k).toLowerCase();
  if(['LeaseSF','AggregateLeasedSFOrCompTotal','LeasedSF','RBA','DirectVacantSF','AvailableSF','TotalAvailableSF','VacantSF'].includes(k))return fullSf(v);
  if(/rentescalation|escalation/i.test(k))return String(v).replace(/\s*annually\b/i,'').replace(/\s*PSF\s*annually\b/i,' PSF/YR').replace(/PSF\/yr/i,'PSF/YR');
  if(/freerentmonths|free rent/i.test(k)){const n=toNum(v); return n===null?String(v):n.toFixed(n%1?1:0)+' mo.';}
  if(/expirationyear|yearbuilt|yearrenovated|year$/i.test(k))return fmtYear(v);
  if(/monthstoexpiration|leasetermmonths/i.test(k))return monthsVal(v);
  if(/rentdeltapct|deltapercent|delta_pct|delta percent/i.test(k))return signedPct(v);
  if(/vacancyrate|percentleased|pct|percentage|rate$/i.test(k)&&!/rent|escalation/i.test(k))return pctVal(v);
  if(/rentdeltapsf|delta psf|rent delta/i.test(k))return deltaPsf(v);
  if(/rent|psf|marketbenchmark|ner/i.test(k)&&typeof v!=='boolean')return moneyPsf(v);
  if(/sf|rba|building size|inventory|available|vacant/i.test(k)&&typeof v==='number')return sf(v);
  if(/latitude|longitude/i.test(k)){const n=toNum(v); return n===null?String(v):n.toFixed(6)}
  if(typeof v==='number')return fmt(v);
  return String(v);
}
function valueClass(k,v,o){
  const key=String(k).toLowerCase(); const pos=String((o&&o.RentPosition)||'').toLowerCase(); const n=toNum(v);
  if(key.includes('rentposition')){if(pos.includes('above'))return 'positive'; if(pos.includes('below'))return 'negative';}
  if(key.includes('rentdeltapsf')||key.includes('rentdeltapct')||key.includes('delta')){if(n>0)return 'positive'; if(n<0)return 'negative';}
  if((key.includes('currentrent')||key.includes('current rent'))&&pos.includes('below'))return 'negative';
  if((key.includes('currentrent')||key.includes('current rent'))&&pos.includes('above'))return 'positive';
  return '';
}
function cell(k,v,o){return fmtValue(k,v,o||null)}
function kv(k,v,cls){return '<div class="kv"><div class="k">'+k+'</div><div class="v '+(cls||'')+'">'+(v||'—')+'</div></div>'}
function kvField(k,v,o){return kv(label(k),fmtValue(k,v,o),valueClass(k,v,o))}
function card(o,i){if(activeTab==='events'){const ei=EVENTS_SAFE.indexOf(o);return '<div class="record" data-i="'+i+'"><div class="record-title">'+(o.Tenant||'Tenant')+'</div><div class="record-sub">'+[o.StreetAddress,o.City,o.State].filter(Boolean).join(', ')+'</div><div class="meta">'+kv('SF',sf(num(o,['LeasedSF'])))+kv('Exp.',o.LeaseExpirationDate)+kv('Current',moneyPsf(currentRentFor(o)),valueClass('CurrentRentPSF',currentRentFor(o),o))+kv('Market',moneyPsf(marketRentFor(o)))+kv('$ delta',deltaPsf(rentDeltaFor(o)),valueClass('RentDeltaPSF',rentDeltaFor(o),o))+kv('% delta',signedPct(rentDeltaPctFor(o)),valueClass('RentDeltaPct',rentDeltaPctFor(o),o))+kv('Rent position',rentPositionFor(o),valueClass('RentPosition',rentPositionFor(o),o))+kv('Landlord',landlordFor(o))+'</div><div class="actions"><button class="mini yellow" data-email="'+ei+'">Copy email prompt</button><button class="mini">Open details</button></div></div>'} if(activeTab==='comps')return '<div class="record" data-i="'+i+'"><div class="record-title">'+(o.Tenant||'Lease comp')+'</div><div class="record-sub">'+[o.StreetAddress,o.City,o.State].filter(Boolean).join(', ')+'</div><div class="meta">'+kv('Square feet',fullSf(num(o,['LeaseSF','AggregateLeasedSFOrCompTotal'])))+kv('Starting rent',moneyPsf(compRentVal(o)))+kv('NER',moneyPsf(compNerVal(o)))+kv('Executed',o.ExecutionDate)+kv('Term',o.LeaseTermMonths?o.LeaseTermMonths+' mo.':'—')+kv('Free rent',compFreeRentVal(o)!==null?compFreeRentVal(o)+' mo.':'—')+kv('TI / PSF',moneyPsf(compTiVal(o)))+kv('Landlord',landlordFor(o))+'</div></div>'; if(activeTab==='rents')return '<div class="record" data-i="'+i+'"><div class="record-title">'+(o.label||o.region)+'</div><div class="record-sub">'+(o.report_date||'')+'</div><div class="meta">'+kv('Asking rent',moneyPsf(o.overall_asking_rent))+kv('Vacancy',pctVal(o.overall_vacancy_pct))+kv('Inventory',o.inventory_msf?o.inventory_msf+' MSF':'—')+kv('Source','Savills / master data')+'</div></div>'; return '<div class="record" data-i="'+i+'"><div class="record-title">'+(o.PropertyName||o.StreetAddress||'Building')+'</div><div class="record-sub">'+[o.StreetAddress,o.City,o.State].filter(Boolean).join(', ')+'</div><div class="meta">'+kv('RBA',sf(num(o,['RBA'])))+kv('Owner / landlord',o.OwnerTableDisplay||o.OwnerLandlordDisplay||o.OwnerDisplay||o.OwnerName)+kv('Vacant',sf(num(o,['DirectVacantSF'])))+kv('Submarket',o.Submarket)+'</div></div>'}
function addRegionLabels(){if(!map||!window.L)return; if(labelLayer){map.removeLayer(labelLayer)} labelLayer=L.layerGroup().addTo(map); const labels=[['Pennsylvania',40.55,-76.45,'state'],['New Jersey',40.15,-74.55,'state'],['Delaware',39.15,-75.45,'state'],['Lehigh County',40.62,-75.58,'county'],['Northampton County',40.76,-75.30,'county'],['Berks County',40.38,-75.96,'county'],['Bucks County',40.33,-75.13,'county'],['Montgomery County',40.22,-75.37,'county'],['Philadelphia County',39.99,-75.13,'county'],['Burlington County',39.88,-74.72,'county'],['Camden County',39.81,-74.98,'county'],['Gloucester County',39.72,-75.15,'county'],['Mercer County',40.26,-74.70,'county'],['Middlesex County',40.45,-74.40,'county'],['Somerset County',40.58,-74.62,'county'],['Union County',40.66,-74.31,'county'],['Essex County',40.78,-74.24,'county'],['Bergen County',40.96,-74.05,'county'],['Hudson County',40.74,-74.06,'county'],['Morris County',40.86,-74.55,'county'],['Dauphin County',40.41,-76.79,'county'],['Cumberland County',40.16,-77.26,'county']]; labels.forEach(([name,lat,lng,type])=>{L.marker([lat,lng],{interactive:false,icon:L.divIcon({className:'',html:'<div class="geo-label '+type+'">'+name+'</div>',iconSize:[120,18],iconAnchor:[60,9]})}).addTo(labelLayer);});}
function initMap(){if(!window.L){$('map').innerHTML='<div class="error">Map library did not load. Data tables are still available below.</div>';return} try{map=L.map('map',{zoomControl:true,preferCanvas:true}).setView([40.25,-75.1],8);L.tileLayer('https://server.arcgisonline.com/ArcGIS/rest/services/World_Imagery/MapServer/tile/{z}/{y}/{x}',{attribution:'Tiles © Esri'}).addTo(map);referenceLabels=L.tileLayer('https://services.arcgisonline.com/ArcGIS/rest/services/Reference/World_Boundaries_and_Places/MapServer/tile/{z}/{y}/{x}',{attribution:'Labels © Esri',pane:'overlayPane'}).addTo(map);addRegionLabels();markers=L.layerGroup().addTo(map);}catch(e){$('map').innerHTML='<div class="error">Map failed to initialize. Data tables are still available below.</div>';}}
function popupHtml(o,idx){
  const b=(o.BuildingID&&byId.get(o.BuildingID))||o;
  const title=o.Tenant||b.PropertyName||o.PropertyName||o.StreetAddress||'Building profile';
  const sub=[b.StreetAddress||o.StreetAddress,b.City||o.City,b.State||o.State].filter(Boolean).join(', ');
  const sfv=sf(num(b,['RBA','RentableBuildingArea'])||num(o,['LeasedSF','LeaseSF','RBA']));
  const owner=b.OwnerName||o.OwnerName||o.LandlordOwner||o.OwnerLandlord||'—';
  return '<div class="map-popup"><div class="map-popup-title">'+esc(title)+'</div><div class="map-popup-sub">'+esc(sub)+'</div><div class="map-popup-meta"><div><div class="map-popup-k">Size</div><div class="map-popup-v">'+esc(sfv)+'</div></div><div><div class="map-popup-k">Owner</div><div class="map-popup-v">'+esc(owner)+'</div></div></div><button class="map-popup-btn" data-map-profile="'+idx+'">Open building profile</button></div>';
}
function openMapProfile(idx){
  const source=mapLayer==='events'?eventRows():mapLayer==='comps'?compRows():buildingRows();
  const mappable=source.filter(o=>Number(o.Latitude||o.lat)&&Number(o.Longitude||o.lng));
  const o=mappable[Number(idx)];
  if(!o)return;
  const b=(o.BuildingID&&byId.get(o.BuildingID))||o;
  openDetail(b);
}
function renderMap(){let source=mapLayer==='events'?eventRows():mapLayer==='comps'?compRows():buildingRows(); source=source.filter(o=>Number(o.Latitude||o.lat)&&Number(o.Longitude||o.lng)); if(!map||!markers){updateMapStats(source);return} markers.clearLayers(); const isMobile=innerWidth<=760; const cap=isMobile?250:450; const pts=[]; source.slice(0,cap).forEach((o,idx)=>{const lat=Number(o.Latitude||o.lat), lng=Number(o.Longitude||o.lng); if(!lat||!lng)return; pts.push([lat,lng]); const cls=(mapLayer==='events'&&String(o.BDPriority||'').toLowerCase().includes('high'))?'#CE181E':'#8d99aa'; const icon=L.divIcon({className:'',html:'<div style="width:16px;height:16px;border-radius:50%;background:'+cls+';border:3px solid #fff;box-shadow:0 1px 5px rgba(0,0,0,.45)"></div>',iconSize:[16,16]}); L.marker([lat,lng],{icon}).bindPopup(popupHtml(o,idx)).addTo(markers);}); updateMapStats(source); if(pts.length){try{map.fitBounds(pts.slice(0,120).map(p=>p),{padding:[30,30],maxZoom:isMobile?9:10})}catch(e){}}}
function updateMapStats(source){$('m-count').textContent=fmt(source.length);$('m-priority').textContent=fmt(source.filter(o=>String(o.BDPriority||'').toLowerCase().includes('high')).length);$('m-window').textContent=fmt(source.filter(o=>/0.?36|0-36|12-24|24-36/i.test(String(o.ExpirationWindow||''))).length);$('m-sf').textContent=sf(source.reduce((s,o)=>s+num(o,['LeasedSF','LeaseSF','RBA']),0));}
function openDetail(o){if(!o)return; const title=o.Tenant||o.PropertyName||o.StreetAddress||o.label||o.region||'Record'; $('detailTitle').textContent=title; $('detailSub').textContent=[o.StreetAddress,o.City,o.State].filter(Boolean).join(', ')||o.report_date||''; $('detailBody').innerHTML=detailHtml(o); $('detail').classList.add('open'); $('detailBody').querySelectorAll('[data-copy-detail]').forEach(b=>b.onclick=()=>copyPrompt(o));}

function buildingIdForRecord(o){if(!o)return ''; if(o.BuildingID)return o.BuildingID; if(o.CoStarPropertyID){const b=BUILDINGS_SAFE.find(x=>String(x.CoStarPropertyID||x.PropertyID||'')===String(o.CoStarPropertyID)); if(b)return b.BuildingID;} return '';}
function compsForBuildingRecord(o){
  const bid=buildingIdForRecord(o);
  const addr=String(o.StreetAddress||'').toLowerCase().trim();
  const city=String(o.City||'').toLowerCase().trim();
  const exact=COMPS_SAFE.filter(c=>bid&&c.BuildingID===bid);
  const fallback=COMPS_SAFE.filter(c=>{
    if(!addr)return false;
    const ca=String(c.StreetAddress||'').toLowerCase().trim();
    const cc=String(c.City||'').toLowerCase().trim();
    return ca===addr&&(!city||!cc||cc===city);
  });
  const seen=new Set(); const all=[];
  [...exact,...fallback].forEach(c=>{const id=c.CompEventID||c.LeaseCompID||JSON.stringify([c.Tenant,c.StreetAddress,c.ExecutionDate,c.StartingRentPSF]); if(!seen.has(id)){seen.add(id); all.push(c);}});
  all.sort((a,b)=>String(b.ExecutionDate||b.CommencementDate||b.ExpirationDate||'').localeCompare(String(a.ExecutionDate||a.CommencementDate||a.ExpirationDate||'')));
  return all;
}
function compMini(k,v){return '<div><div class="comp-mini-k">'+esc(k)+'</div><div class="comp-mini-v">'+esc(v||'—')+'</div></div>'}
function relatedCompsHtml(o){
  const comps=compsForBuildingRecord(o);
  const isBuilding=!!(o&&o.BuildingID&&BUILDINGS_SAFE.some(b=>b.BuildingID===o.BuildingID));
  if(!isBuilding&&!comps.length)return '';
  let html='<div class="detail-section"><h4>Historical lease comps attached to this building</h4>';
  html+='<div class="comp-note">'+fmt(comps.length)+' comp record'+(comps.length===1?'':'s')+' matched to this building'+(comps.length?' and sorted most recent first.':' - no matched comp records currently tied to this building.')+'</div>';
  if(comps.length){
    html+='<div class="related-comps">';
    comps.forEach(c=>{
      html+='<div class="comp-row"><div class="comp-row-head"><div class="comp-tenant">'+esc(c.Tenant||'Unknown tenant')+'</div><div class="comp-date">'+esc(c.ExecutionDate||c.CommencementDate||c.ExpirationDate||'Date unavailable')+'</div></div>';
      html+='<div class="comp-grid">'
        +compMini('Lease SF',sf(num(c,['LeaseSF','AggregateLeasedSFOrCompTotal'])))
        +compMini('Starting rent',moneyPsf(compRentVal(c)))
        +compMini('NER',moneyPsf(compNerVal(c)))
        +compMini('Term',c.LeaseTermMonths?c.LeaseTermMonths+' mo.':'—')
        +compMini('Free rent',compFreeRentVal(c)!==null?compFreeRentVal(c)+' mo.':'—')
        +compMini('TI / PSF',moneyPsf(compTiVal(c)))
        +compMini('Type',c.TransactionType||'—')
        +compMini('Landlord',c.OwnerLandlord||'—')
        +compMini('Commenced',c.CommencementDate||'—')
        +compMini('Expires',c.ExpirationDate||'—')
        +compMini('Rent type',c.RentTypeClean||c.RentType||'—')
        +compMini('Escalation',c.RentEscalationClean||c.RentEscalation||'—')
        +'</div></div>';
    });
    html+='</div>';
  }
  html+='</div>';
  return html;
}


function displayValueForProfile(k,v,o){
  if(isNil(v))return '';
  const s=fmtValue(k,v,o);
  return s==='—'?'':s;
}
function profileField(labelText,value,cls){
  if(isNil(value)||value==='—'||String(value).trim()==='')return '';
  return '<div><div class="k">'+esc(labelText)+'</div><div class="v '+(cls||'')+'">'+esc(value)+'</div></div>';
}
function profileSection(title,fields){
  const body=fields.filter(Boolean).join('');
  if(!body)return '';
  return '<div class="detail-section"><h4>'+esc(title)+'</h4><div class="meta">'+body+'</div></div>';
}
function firstVal(){
  for(let i=0;i<arguments.length;i++){
    const v=arguments[i];
    if(v!==undefined&&v!==null&&String(v).trim()!==''&&String(v).trim()!=='—')return v;
  }
  return '';
}
function ownerProfileValue(o){
  return tableOwnerValue(o)||landlordFor(o)||'';
}
function isLeaseEventRecord(o){
  return !!(o&&o.BDOpportunityID);
}
function isCompRecord(o){
  return !!(o&&(o.CompEventID||o.LeaseCompID||o.SourceRecordType==='Savills CSV'||o.StartingRentPSF!==undefined)&&!o.BDOpportunityID);
}
function isBuildingRecord(o){
  return !!(o&&BUILDINGS_SAFE.some(b=>b.BuildingID===o.BuildingID)&&!o.BDOpportunityID&&!o.CompEventID&&!o.LeaseCompID);
}
function idsProfileSection(o){
  const fields=[
    profileField('B D opportunity ID',o.BDOpportunityID),
    profileField('Building ID',o.BuildingID),
    profileField('CoStar property ID',o.CoStarPropertyID||o.PropertyID),
    profileField('Comp event ID',o.CompEventID),
    profileField('Lease comp ID',o.LeaseCompID),
    profileField('Source batch',o.SourceBatch),
    profileField('Source screenshot',o.SourceScreenshot)
  ];
  return profileSection('Internal IDs / source references',fields);
}
function leaseEventProfile(o){
  const owner=ownerProfileValue(o);
  const b=matchedBuildingFor(o)||{};
  const fields1=[
    profileField('Tenant',o.Tenant),
    profileField('Address',[o.StreetAddress,o.City,o.State].filter(Boolean).join(', ')),
    profileField('Owner / landlord',owner),
    profileField('Region',o.Region||b.Region),
    profileField('Market',o.Market||b.Market),
    profileField('Submarket',o.Submarket||b.Submarket),
    profileField('Leased SF',fullSf(o.LeasedSF)),
    profileField('Expiration',o.LeaseExpirationDate),
    profileField('Expiration window',o.ExpirationWindow),
    profileField('Months to expiration',displayValueForProfile('MonthsToExpiration',o.MonthsToExpiration,o)),
    profileField('BD priority',o.BDPriority),
    profileField('Contact status',o.ContactStatus)
  ];
  const fields2=[
    profileField('Current rent',moneyPsf(currentRentFor(o)),valueClass('CurrentRentPSF',currentRentFor(o),o)),
    profileField('Market rent',moneyPsf(marketRentFor(o))),
    profileField('$ delta',deltaPsf(rentDeltaFor(o)),valueClass('RentDeltaPSF',rentDeltaFor(o),o)),
    profileField('% above/below',signedPct(rentDeltaPctFor(o)),valueClass('RentDeltaPct',rentDeltaPctFor(o),o)),
    profileField('Rent position',rentPositionFor(o),valueClass('RentPosition',rentPositionFor(o),o)),
    profileField('Source confidence',o.SourceConfidence)
  ];
  const fields3=[
    profileField('Building name',b.PropertyName||o.MatchedPropertyName),
    profileField('RBA',fullSf(b.RBA)),
    profileField('Direct vacant SF',fullSf(b.DirectVacantSF||b.VacantSF)),
    profileField('Available SF',fullSf(b.AvailableSF||b.TotalAvailableSF)),
    profileField('Clear height',b.CeilingHt),
    profileField('Docks',b.LoadingDocks),
    profileField('Drive-ins',b.DriveIns),
    profileField('Year built',b.YearBuilt),
    profileField('Leasing company',b.LeasingCompanyName),
    profileField('Broker / contact',[b.PrimaryAgentName,b.LeasingCompanyContact].filter(Boolean).join(' / '))
  ];
  return profileSection('Lease event summary',fields1)+profileSection('Rent and leverage',fields2)+profileSection('Building context',fields3)+idsProfileSection(o);
}
function buildingProfile(o){
  const owner=ownerProfileValue(o);
  const fields1=[
    profileField('Building',o.PropertyName||o.StreetAddress),
    profileField('Address',[o.StreetAddress,o.City,o.State].filter(Boolean).join(', ')),
    profileField('Owner / landlord',owner),
    profileField('Region',o.Region),
    profileField('Market',o.Market),
    profileField('Submarket',o.Submarket),
    profileField('RBA',fullSf(o.RBA)),
    profileField('Building class',o.BuildingClass),
    profileField('Building type',o.BuildingType),
    profileField('Year built',o.YearBuilt),
    profileField('Year renovated',o.YearRenovated)
  ];
  const fields2=[
    profileField('Direct vacant SF',fullSf(o.DirectVacantSF||o.VacantSF)),
    profileField('Available SF',fullSf(o.AvailableSF||o.TotalAvailableSF)),
    profileField('Percent leased',pctVal(o.PercentLeased)),
    profileField('Market rent',moneyPsf(o.MarketRentPSF||o.AvgDirectRentIndustrial)),
    profileField('Office space',fullSf(o.OfficeSpace)),
    profileField('Land area',o.LandAreaAC?fmt(o.LandAreaAC)+' AC':'')
  ];
  const fields3=[
    profileField('Clear height',o.CeilingHt),
    profileField('Loading docks',o.LoadingDocks),
    profileField('Drive-ins',o.DriveIns),
    profileField('Column spacing',o.ColumnSpacing),
    profileField('Sprinklers',o.Sprinklers),
    profileField('Power',o.Power),
    profileField('Building park',o.BuildingPark)
  ];
  const fields4=[
    profileField('Developer',o.DeveloperName),
    profileField('Leasing company',o.LeasingCompanyName),
    profileField('Leasing contact',o.LeasingCompanyContact),
    profileField('Primary agent',o.PrimaryAgentName)
  ];
  return profileSection('Building summary',fields1)+profileSection('Availability and rent',fields2)+profileSection('Physical specifications',fields3)+profileSection('Leasing / ownership context',fields4)+idsProfileSection(o);
}
function compProfile(o){
  const owner=ownerProfileValue(o);
  const fields1=[
    profileField('Tenant',o.Tenant),
    profileField('Address',[o.StreetAddress,o.City,o.State].filter(Boolean).join(', ')),
    profileField('Owner / landlord',owner),
    profileField('Region',o.Region),
    profileField('Submarket',o.CompSubmarketDisplay||o.Submarket),
    profileField('Lease type',o.TransactionType),
    profileField('Lease SF',fullSf(o.LeaseSF||o.AggregateLeasedSFOrCompTotal)),
    profileField('Executed',o.ExecutionDate),
    profileField('Commenced',o.CommencementDate),
    profileField('Expires',o.ExpirationDate),
    profileField('Term',o.LeaseTermMonths?o.LeaseTermMonths+' mo.':'')
  ];
  const fields2=[
    profileField('Starting rent',moneyPsf(compRentVal(o))),
    profileField('NER',moneyPsf(compNerVal(o))),
    profileField('Annual escalation',o.RentEscalationClean),
    profileField('Free rent',compFreeRentVal(o)!==null?compFreeRentVal(o)+' mo.':''),
    profileField('TI / PSF',moneyPsf(compTiVal(o))),
    profileField('Rent type',o.RentTypeClean||o.RentType)
  ];
  return profileSection('Comp summary',fields1)+profileSection('Comp economics',fields2)+idsProfileSection(o);
}

function detailHtml(o){
  let html='';
  if(isLeaseEventRecord(o))html=leaseEventProfile(o);
  else if(isBuildingRecord(o))html=buildingProfile(o);
  else if(isCompRecord(o))html=compProfile(o);
  else html=profileSection('Record summary',[
    profileField('Name',o.Tenant||o.PropertyName||o.StreetAddress),
    profileField('Address',[o.StreetAddress,o.City,o.State].filter(Boolean).join(', ')),
    profileField('Owner / landlord',ownerProfileValue(o)),
    profileField('Region',o.Region),
    profileField('Market',o.Market),
    profileField('Submarket',o.Submarket)
  ])+idsProfileSection(o);
  html+=relatedCompsHtml(o);
  if(o.BDOpportunityID||o.Tenant){html+='<button class="mini yellow" data-copy-detail>Copy two-version email prompt</button>'}
  return html;
}
function copyPrompt(o){
  if(!o)return;
  const b=byId.get(o.BuildingID)||{};
  const comps=COMPS_SAFE.filter(c=>c.BuildingID&&c.BuildingID===o.BuildingID).slice(0,8);
  const tenant=o.Tenant||'';
  const address=[o.StreetAddress,o.City,o.State].filter(Boolean).join(', ');
  const city=o.City||'';
  const submarket=o.Submarket||b.Submarket||'';
  const corridor=o.Region||b.Region||o.Market||b.Market||'';
  const landlord=landlordFor(o)||b.OwnerTableDisplay||b.OwnerLandlordDisplay||b.OwnerDisplay||'';
  const leasedSf=sf(num(o,['LeasedSF']));
  const exp=o.LeaseExpirationDate||'';
  const expWindow=o.ExpirationWindow||'';
  const current=moneyPsf(currentRentFor(o));
  const market=moneyPsf(marketRentFor(o));
  const delta=deltaPsf(rentDeltaFor(o))+' / '+signedPct(rentDeltaPctFor(o));
  const rentPos=rentPositionFor(o)||'';
  const vacancy=b.ResearchVacancyRate?pctVal(b.ResearchVacancyRate):(b.PercentLeased?pctVal(100-toNum(b.PercentLeased)):'');
  const vacant=sf(num(b,['DirectVacantSF','VacantSF']));
  const avail=sf(num(b,['AvailableSF','TotalAvailableSF']));
  const compLines=comps.length?comps.map(c=>`- ${c.Tenant||c.PropertyName||'Comp'}: ${sf(num(c,['LeaseSF','AggregateLeasedSFOrCompTotal']))}, starting rent ${moneyPsf(num(c,['StartingRentPSF']))}, NER ${moneyPsf(compNerVal(c))}, ${c.ExecutionDate||c.CommencementDate||''}, ${c.TransactionType||''}`).join('\n'):'No matched same-building comps available. Use nearby/regional comp and market benchmark context instead.';
  const prompt=`Create two prospecting email drafts for John Leskow / Parker Wolf at Savills using the full market context below.

Use tenant-representation language. Avoid "compare notes" and "worth a conversation." Use "tenant," not "occupier." Keep the tone professional, concise, practical and not salesy. End with "Would you be interested in learning more about our strategy?" when appropriate. Do not use em dashes.

Core strategy to reflect in both drafts:
Landlords often view industrial tenants as captive when the tenant has invested capital in the facility, has operational disruption risk, or faces meaningful cost to move. The email should frame Savills as helping the tenant avoid being treated like a captive renewal by creating credible market competition, testing realistic alternatives, and using that leverage to improve the economics at the building the tenant ultimately prefers. Keep this consultative and disciplined, not aggressive.

Version 1:
- Short CTA email, ideally under 75 words, with a 1-4 word trigger-based subject line.
- Tie the message to the lease event and the risk of losing leverage if the landlord assumes the tenant is unlikely to move.
- Ask whether it would be useful to review a custom report of the submarket.
- Make it specific to the tenant, address, expiration window/date, corridor/submarket, vacancy and landlord if available.
- Keep it direct and not over-explained.

Version 2:
- Short CTA email, ideally under 75 words, with a 1-4 word trigger-based subject line.
- Tie the message to the lease event and the risk of losing leverage if the landlord assumes the tenant is unlikely to move.
- Use a recent customer story example to respectfully bait a response.
- Ask whether it would be useful to learn more about our perspective and strategy.
- Use this example as the template and do not change too much of it:

"[NAME],

We recently supported a large industrial tenant with a strategic approach - creating credible market competition to execute an early restructure that protected against an impending rent increase while preserving free rent and other concessions.

Given current vacancy along the [HIGHWAY / CORRIDOR] ([SUBMARKET VACANCY RATE %]) and [TENANT NAME]'s [EXPIRATION MONTH + YEAR] lease expiration at [ADDRESS] - would you be interested in learning more about our approach and how we create leverage for our tenant clients at [EXIT / SUBMARKET IDENTIFIER]?"

Selected lease event:
Tenant: ${tenant}
Address: ${address}
City: ${city}
Leased SF: ${leasedSf}
Expiration: ${exp}
Expiration window: ${expWindow}
Current rent / comp rent: ${current}
Market rent benchmark: ${market}
Rent delta: ${delta}
Rent position: ${rentPos}
BD priority: ${o.BDPriority||''}
Market story: ${o.MarketBDStory||o.InternalEmailBrief||''}
Captive tenant / leverage angle: Landlord may assume renewal control if the tenant has meaningful capital invested, operational disruption risk, or limited credible alternatives. Frame the outreach around creating competition so the tenant preserves leverage and avoids being priced as captive.

Building / CoStar context:
Property: ${b.PropertyName||o.MatchedPropertyName||''}
Owner/landlord: ${landlord}
Region/submarket: ${corridor} / ${submarket}
RBA: ${sf(num(b,['RBA']))}
Market rent benchmark: ${market}
Vacant SF: ${vacant}
Available SF: ${avail}
Vacancy / leased status: ${vacancy}
Clear height: ${b.CeilingHt||''}
Docks: ${b.LoadingDocks||''}
Leasing company/broker: ${[b.LeasingCompanyName,b.PrimaryAgentName,b.LeasingCompanyContact].filter(Boolean).join(' ')}

Matched lease comps at same building:
${compLines}

Output exactly:
Version 1
Subject:
Email body:

Version 2
Subject:
Email body:`;
  if(navigator.clipboard){navigator.clipboard.writeText(prompt).then(()=>toast('Email prompt copied')).catch(()=>fallbackCopy(prompt));}else fallbackCopy(prompt)
}
function fallbackCopy(t){const ta=document.createElement('textarea');ta.value=t;document.body.appendChild(ta);ta.select();document.execCommand('copy');ta.remove();toast('Email prompt copied')}
function toast(t){$('toast').textContent=t;$('toast').classList.add('show');setTimeout(()=>$('toast').classList.remove('show'),1800)}
function openFilters(){$('filters').classList.add('open');$('backdrop').classList.add('open')} function closeFilters(){$('filters').classList.remove('open');$('backdrop').classList.remove('open')}
function bind(){['search','focus','region','submarket','expiration','priority','minsf'].forEach(id=>$(id).addEventListener('input',()=>{if(id==='search' && $('quickSearch'))$('quickSearch').value=$('search').value; activeTab=$('focus').value; setTabs(); render();})); if($('quickSearch')) $('quickSearch').addEventListener('input',()=>{$('search').value=$('quickSearch').value; render();}); $('filterBtn').onclick=()=>{if(innerWidth<=1024) openFilters(); else document.getElementById('filters').scrollIntoView({behavior:'smooth',block:'start'});}; if($('mobileFilterBtn'))$('mobileFilterBtn').onclick=openFilters; if($('filterCloseBtn'))$('filterCloseBtn').onclick=closeFilters; if($('mobileSort'))$('mobileSort').onchange=applyMobileSort; if($('mobileSortDir'))$('mobileSortDir').onclick=()=>{const b=$('mobileSortDir'); b.dataset.dir=(b.dataset.dir==='asc'?'desc':'asc'); b.textContent=b.dataset.dir==='asc'?'Asc':'Desc'; applyMobileSort();}; $('backdrop').onclick=closeFilters; $('resetBtn').onclick=()=>{['search','region','submarket','expiration','priority'].forEach(id=>$(id).value=''); if($('quickSearch')) $('quickSearch').value=''; $('minsf').value='0'; compFilterState={q:'',submarket:'',leaseType:'',size:''}; render();}; $('mapOptBtn').onclick=()=>$('mapMenu').classList.toggle('open'); document.querySelectorAll('[data-layer]').forEach(b=>b.onclick=()=>{document.querySelectorAll('[data-layer]').forEach(x=>x.classList.remove('active'));b.classList.add('active');mapLayer=b.dataset.layer;renderMap();}); document.querySelectorAll('[data-tab]').forEach(b=>b.onclick=()=>{activeTab=b.dataset.tab;$('focus').value=activeTab;setTabs();render();}); document.querySelectorAll('[data-side-tab]').forEach(b=>b.onclick=()=>{activeTab=b.dataset.sideTab;$('focus').value=activeTab;setTabs();render();}); $('detailClose').onclick=()=>$('detail').classList.remove('open'); document.addEventListener('click',e=>{const btn=e.target.closest('[data-map-profile]'); if(btn)openMapProfile(btn.dataset.mapProfile);}); window.addEventListener('resize',()=>setTimeout(()=>{try{if(map)map.invalidateSize(); renderMap();}catch(e){}},180));}
function setTabs(){document.querySelectorAll('[data-tab]').forEach(b=>b.classList.toggle('active',b.dataset.tab===activeTab)); document.querySelectorAll('[data-side-tab]').forEach(b=>b.classList.toggle('active',b.dataset.sideTab===activeTab)); if($('focus')) $('focus').value=activeTab;}
try{init()}catch(e){document.body.innerHTML='<div class="error"><b>Dashboard failed to initialize.</b><br>'+String(e)+'</div>'; console.error(e)}
})();
</script>
<script>
/* v49 auth gate */
(function(){
  const AUTH_KEY='savills_industrial_dashboard_auth_until_v49';
  const AUTH_DURATION=7200000;
  const PASSWORD="Jcl19103$$$";
  function now(){return Date.now();}
  function isAuthed(){
    const until=Number(localStorage.getItem(AUTH_KEY)||0);
    return until && until>now();
  }
  function unlock(){
    document.body.classList.remove('auth-locked');
    const gate=document.getElementById('authGate');
    if(gate)gate.classList.add('hidden');
  }
  function lock(){
    document.body.classList.add('auth-locked');
    const gate=document.getElementById('authGate');
    if(gate)gate.classList.remove('hidden');
    setTimeout(()=>{const input=document.getElementById('dashboardPassword'); if(input)input.focus();},50);
  }
  function authenticate(){
    const input=document.getElementById('dashboardPassword');
    const err=document.getElementById('authError');
    if(input && input.value===PASSWORD){
      localStorage.setItem(AUTH_KEY, String(now()+AUTH_DURATION));
      if(err)err.classList.remove('show');
      unlock();
    }else{
      if(err)err.classList.add('show');
      if(input){input.value=''; input.focus();}
    }
  }
  document.addEventListener('DOMContentLoaded',()=>{
    if(isAuthed())unlock(); else lock();
    const btn=document.getElementById('authSubmit');
    const input=document.getElementById('dashboardPassword');
    if(btn)btn.addEventListener('click',authenticate);
    if(input)input.addEventListener('keydown',e=>{if(e.key==='Enter')authenticate();});
    setInterval(()=>{if(!isAuthed())lock();},60000);
  });
})();
</script>
<script>
(function(){
  function closeIntro(){
    const splash=document.getElementById('introSplash');
    if(!splash)return;
    splash.classList.add('hide');
    setTimeout(()=>{ if(splash&&splash.parentNode) splash.parentNode.removeChild(splash); },850);
  }
  window.addEventListener('load',()=>setTimeout(closeIntro,3000));
})();
</script>
</body>
</html>
