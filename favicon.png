  .status-chip{display:none}
}
@media(max-width:1120px){
  .topbar{grid-template-columns:1fr auto;grid-template-areas:"brand filter" "search search";gap:12px}
  .brand-cluster{grid-area:brand}
  .toolbar{grid-area:search;width:100%}
  .filter-btn{grid-area:filter}
  .toolbar-search{display:flex;max-width:none}
  .title{max-width:100%;font-size:clamp(26px,4vw,36px)!important}
}
@media(max-width:760px){
  .topbar{display:flex;align-items:center}
  .title{font-size:22px!important;line-height:1.05!important}
  .toolbar{display:none}
}

/* Market AI cards - prevent collisions and oversized metric numbers */
.ai-report-grid{
  grid-template-columns:repeat(3,minmax(0,1fr))!important;
  gap:20px!important;
}
.ai-report-card{
  min-width:0!important;
  overflow:hidden!important;
  display:flex!important;
  flex-direction:column!important;
}
.ai-report-card h4{
  font-size:clamp(20px,1.55vw,26px)!important;
  line-height:1.08!important;
  word-break:normal;
  hyphens:none;
}
.ai-report-card .ai-metrics{
  grid-template-columns:repeat(2,minmax(0,1fr))!important;
  gap:10px!important;
}
.ai-report-card .ai-metric{
  min-width:0!important;
  padding:12px!important;
}
.ai-report-card .ai-metric strong{
  font-size:clamp(18px,1.65vw,28px)!important;
  line-height:1.08!important;
  white-space:normal!important;
  overflow-wrap:normal!important;
}
.ai-report-card .ai-metric span{
  font-size:9px!important;
  line-height:1.15!important;
  letter-spacing:1px!important;
}
.ai-report-card p{
  font-size:14px!important;
  line-height:1.38!important;
}
.ai-bars{
  min-width:0!important;
}
.ai-bar-row{
  grid-template-columns:minmax(86px,118px) minmax(70px,1fr) minmax(58px,auto)!important;
  column-gap:8px!important;
}
.ai-bar-row strong{
  font-size:12px!important;
  white-space:nowrap!important;
}
.ai-button{
  min-height:44px;
}
.ai-report-thumb{
  max-height:245px!important;
}
.ai-report-thumb img{
  object-fit:cover!important;
  object-position:top center!important;
}

/* Adjust dashboard content at 90% zoom / narrower desktop widths */
@media(max-width:1500px){
  .ai-report-grid{grid-template-columns:1fr!important}
  .ai-report-card{
    display:grid!important;
