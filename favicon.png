  }
  .sidebar-caption{
    font-size:9px!important;
    margin-bottom:8px!important;
  }
  .nav-stack{
    gap:7px!important;
    margin-bottom:14px!important;
  }
  .sidebar-link{
    padding:10px 12px!important;
    border-radius:12px!important;
    font-size:14px!important;
  }
  .filters h3{
    margin:14px 0 10px!important;
    font-size:10px!important;
  }
  .field{
    margin-bottom:10px!important;
  }
  .field label{
    font-size:9px!important;
    margin-bottom:6px!important;
  }
  .field input,
  .field select{
    height:40px!important;
    border-radius:10px!important;
    font-size:13px!important;
  }
  .reset{
    height:40px!important;
    border-radius:10px!important;
    font-size:13px!important;
  }
  .kpis{
    gap:12px!important;
    margin-bottom:12px!important;
  }
  .kpi{
    min-height:106px!important;
    padding:16px 18px!important;
    border-radius:16px!important;
  }
  .kpi .label{
    font-size:10px!important;
    letter-spacing:1.7px!important;
    margin-bottom:8px!important;
  }
  .kpi .value{
    font-size:clamp(34px,3.0vw,46px)!important;
    line-height:.95!important;
  }
  .kpi .sub{
    font-size:13px!important;
    margin-top:6px!important;
  }
  .map-card{
    height:min(520px,calc(100vh - 238px))!important;
    min-height:360px!important;
    border-radius:18px!important;
  }
  .data-card{
    border-radius:18px!important;
  }
  .tabs{
    padding:12px!important;
    gap:10px!important;
  }
  .tab{
    padding:11px 14px!important;
    font-size:15px!important;
    border-radius:16px!important;
  }
  .section-head{
    padding:18px 20px!important;
  }
  .section-head h2{
    font-size:30px!important;
  }
  .section-head p{
    font-size:14px!important;
  }
}
@media(min-width:1025px) and (max-width:1400px){
  .topbar{
    grid-template-columns:minmax(0,1fr) minmax(250px,340px) auto!important;
    gap:16px!important;
    align-items:center!important;
  }
  .title{
    max-width:620px!important;
    font-size:clamp(18px,1.3vw,22px)!important;
    white-space:normal!important;
    overflow:visible!important;
    text-overflow:clip!important;
    line-height:1.02!important;
  }
  .toolbar-search{
    width:min(340px,28vw)!important;
